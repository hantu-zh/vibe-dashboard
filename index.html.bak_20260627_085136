  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>方瑟的openclaw A股情绪雷达</title>


  <style>

    :root {

      --neon-pink: #ff2d6a;

      --neon-cyan: #00fff2;

      --neon-purple: #b829ff;

      --neon-green: #39ff14;

      --neon-red: #ff2d2d;

      --neon-orange: #ff6b35;

      --dark-bg: #0a0a0f;

      --card-bg: rgba(15, 15, 25, 0.85);

      --border-glow: rgba(255, 45, 106, 0.3);

    }


    * { margin: 0; padding: 0; box-sizing: border-box; }


    body {

      font-family: 'Noto Sans SC', sans-serif;

      background: var(--dark-bg);

      color: #e0e0e0;

      min-height: 100vh;

      overflow-x: hidden;

      position: relative;

    }


    body::before {

      content: '';

      position: fixed;

      top: 0; left: 0;

      width: 100%; height: 100%;

      background: 

        linear-gradient(90deg, rgba(255,45,106,0.03) 1px, transparent 1px),

        linear-gradient(rgba(0,255,242,0.03) 1px, transparent 1px);

      background-size: 50px 50px;

      animation: gridMove 20s linear infinite;

      pointer-events: none;

      z-index: 0;

    }


    @keyframes gridMove {

      0% { transform: translate(0, 0); }

      100% { transform: translate(50px, 50px); }

    }


    body::after {

      content: '';

      position: fixed;

      top: 0; left: 0;

      width: 100%; height: 4px;

      background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);

      animation: scanLine 4s ease-in-out infinite;

      pointer-events: none;

      z-index: 1000;

      opacity: 0.5;

    }


    @keyframes scanLine {

      0%, 100% { top: -10px; opacity: 0; }

      50% { opacity: 0.7; }

      100% { top: 100%; }

    }


    .container {

      position: relative;

      z-index: 1;

      max-width: 1800px;

      margin: 0 auto;

      padding: 20px;

    }


    .header {

      text-align: center;

      margin-bottom: 25px;

      padding: 15px;

    }


    .logo {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 2.5rem;

      font-weight: 900;

      letter-spacing: 6px;

      background: linear-gradient(135deg, var(--neon-red), var(--neon-orange), var(--neon-pink));

      -webkit-background-clip: text;

      -webkit-text-fill-color: transparent;

      background-clip: text;

      animation: logoPulse 2s ease-in-out infinite;

    }


    @media (max-width: 768px) {

      .logo { font-size: 1.3rem; letter-spacing: 2px; }

      .tagline { font-size: 0.65rem; letter-spacing: 1px; }

    }


    @keyframes logoPulse {

      0%, 100% { filter: brightness(1); }

      50% { filter: brightness(1.2); }

    }


    .tagline {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.85rem;

      color: var(--neon-cyan);

      letter-spacing: 3px;

      margin-top: 8px;

    }


    .status-bar {

      display: flex;

      justify-content: center;

      gap: 25px;

      margin-top: 15px;

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.7rem;

    }


    .status-item {

      display: flex;

      align-items: center;

      gap: 6px;

    }


    .status-dot {

      width: 8px; height: 8px;

      border-radius: 50%;

      animation: blink 1.5s ease-in-out infinite;

    }


    .status-dot.active { background: var(--neon-green); box-shadow: 0 0 10px var(--neon-green); }

    .status-dot.warning { background: var(--neon-orange); box-shadow: 0 0 10px var(--neon-orange); }

    .status-dot.error { background: var(--neon-red); box-shadow: 0 0 10px var(--neon-red); }


    @keyframes blink {

      0%, 100% { opacity: 1; }

      50% { opacity: 0.4; }

    }


    .dashboard-grid {

      display: grid;

      grid-template-columns: 280px 1fr 320px;

      grid-template-rows: auto auto auto auto auto auto;

      gap: 18px;

    }


    .card {

      background: var(--card-bg);

      border: 1px solid var(--border-glow);

      border-radius: 10px;

      padding: 18px;

      position: relative;

      overflow: hidden;

      backdrop-filter: blur(10px);

      transition: all 0.3s ease;

    }


    .card::before {

      content: '';

      position: absolute;

      top: 0; left: 0; right: 0;

      height: 2px;

      background: linear-gradient(90deg, transparent, var(--neon-pink), transparent);

    }


    .card:hover {

      border-color: var(--neon-pink);

      box-shadow: 0 0 25px rgba(255, 45, 106, 0.15);

    }


    
    .title-icon {
      font-size: 1.1em;
      margin-right: 8px;
    }
    .title-hint {
      font-size: 0.6em;
      color: rgba(255,255,255,0.4);
      background: rgba(255,255,255,0.05);
      padding: 2px 8px;
      border-radius: 4px;
      margin-left: 8px;
    }

    
    /* RPS 荧光样式 */

    .rps-stat {
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 0.75rem;
    }
    .rps-stat.strong {
      background: rgba(255, 0, 40, 0.2);
      color: #ff0028;
      box-shadow: 0 0 10px rgba(255, 0, 40, 0.3);
    }
    .rps-stat.weak {
      background: rgba(57, 255, 20, 0.15);
      color: #39ff14;
      box-shadow: 0 0 10px rgba(57, 255, 20, 0.3);
    }
    .rps-divider {
      color: rgba(255,255,255,0.3);
      margin: 0 8px;
    }
    .rps-formula {
      color: rgba(255,255,255,0.5);
      font-size: 0.7rem;
    }


    .rps-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }
    .rps-table {
      background: rgba(255, 255, 255, 0.02);
      border-radius: 8px;
      overflow: hidden;
    }
    .rps-table th {
      background: linear-gradient(90deg, rgba(255,0,40,0.15) 0%, rgba(255,0,146,0.15) 100%);
      color: rgba(255,255,255,0.8);
      padding: 10px 8px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .rps-table td {
      padding: 8px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.75rem;
    }
    .rps-table tr:hover {
      background: rgba(255,0,146,0.08);
    }
    .rps-bar {
      height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.1);
      overflow: hidden;
      position: relative;
    }
    .rps-bar::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%);
      animation: rps-shine 2s infinite;
    }
    @keyframes rps-shine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
    .rps-num {
      font-weight: 600;
      text-shadow: 0 0 8px currentColor;
    }
    .rps-strength {
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 0.65rem;
      font-weight: 500;
      text-transform: uppercase;
    }
    .rps-sector-name {
      font-weight: 500;
    }

    .card-title {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.75rem;

      letter-spacing: 2px;

      color: var(--neon-cyan);

      margin-bottom: 12px;

      text-transform: uppercase;

      display: flex;

      align-items: center;

      gap: 8px;

    }


    .card-title::before { content: '>'; color: var(--neon-pink); }


    /* Sentiment Meter */

    .sentiment-meter {

      grid-column: 1;

      grid-row: 1;

    }


    .slowrise-panel { display: none; }


    .sector-panel {

      grid-column: 2;

      grid-row: 1;

      width: 100%;

      min-width: 0;

    }


    .stock-panel {

      grid-column: 1 / -1;

      grid-row: 2;

    }


    .alert-panel {

      grid-column: 3;

      grid-row: 2;

      overflow: visible !important;

    }

/* US Stock Picks Panel - 放在异动面板下方 */
    .us-stock-panel {
      grid-column: 1 / -1;
