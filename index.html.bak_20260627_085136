<script>
// Fear & Greed Index Auto-Update
(function() {
  const FEAR_GREED_API = 'https://api.alternative.me/fng/';
  
  function updateFearGreed(data) {
    const valueEl = document.getElementById('fear-greed-value');
    if (!valueEl) return;
    
    // API returns: {"data":[{"value":"30","value_classification":"Extreme Fear","timestamp":"..."}]}
    try {
      const json = typeof data === 'string' ? JSON.parse(data) : data;
      const fgi = json.data && json.data[0];
      if (fgi) {
        const rawVal = parseInt(fgi.value);
        const val = isNaN(rawVal) ? 30 : rawVal;  // Fix: handle value=0 correctly
        console.log('Fear-Greed API value:', fgi.value, '-> parsed:', rawVal, '-> display:', val);
        valueEl.textContent = val;
        
        // Update needle rotation: 0=extreme fear(far left), 50=neutral(center/up), 100=extreme greed(far right)
        // Map 0-100 to -90 to +90 degrees (180-degree gauge arc)
        const needle = document.getElementById('fear-greed-needle');
        if (needle) {
          const angle = -90 + (val / 100) * 180;  // 0->-90(left), 50->0(center), 100->+90(right)
          console.log('Fear-Greed needle angle:', angle, 'for value:', val);
          needle.setAttribute('transform', `rotate(${angle} 190 165)`);
        } else {
          console.error('Fear-Greed: needle element not found!');
        }
        
        // Update color based on value — match the 4-color gauge image zones
        // Image layout (left→right): 极度恐惧(绿) → 恐惧(橙) → 贪婪(黄) → 极度贪婪(红)
        let color = '#ffaa33';
        if (val <= 25) color = '#33aa44';      // 极度恐惧 Extreme Fear — green (left zone)
        else if (val <= 50) color = '#ffcc11';  // 恐惧 Fear — yellow-orange (mid-left)
        else if (val <= 75) color = '#ff9922';  // 贪婪 Greed — orange (mid-right)
        else color = '#ee3333';                // 极度贪婪 Extreme Greed — red (right zone)
        
        valueEl.style.color = color;
        valueEl.style.textShadow = `0 0 10px ${color}80`;
      }
    } catch(e) {
      console.log('Fear-Greed parse error:', e);
    }
  }
  
  function fetchFearGreed() {
    fetch(FEAR_GREED_API)
      .then(r => r.text())
      .then(updateFearGreed)
      .catch(e => console.log('Fear-Greed fetch error:', e));
  }
  
  // Fetch on load
  fetchFearGreed();
  
  // Refresh every 5 minutes
  setInterval(fetchFearGreed, 5*60*1000);
})();
</script>


