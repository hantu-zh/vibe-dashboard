    function calculateSentiment(sectors) {

      if (!sectors || sectors.length === 0) {

        return { bullish: 50, neutral: 30, bearish: 20, overall: 50 };

      }

      const up = sectors.filter(s => s.change > 0).length;

      const total = sectors.length;

      const ratio = up / total;


      const bullish = Math.min(70, Math.max(20, ratio * 100));

      const bearish = Math.min(50, Math.max(10, (1 - ratio) * 100));

      const neutral = 100 - bullish - bearish;


      return {

        bullish: Math.round(bullish * 10) / 10,

        neutral: Math.round(neutral * 10) / 10,

        bearish: Math.round(bearish * 10) / 10,

        overall: Math.round(bullish - bearish + 50)

      };

    }


