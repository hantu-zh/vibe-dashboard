<!-- Script 1 -->
<script>
    // FIX: use local timezone for all date calculations (toISOString returns UTC)
    function localDateStr(d) { d = d || new Date(); return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0'); }


    // ============================================================

    // ============================================================
    //  VISIT COUNTER — Busuanzi (busuanzi.cc, cloud persistent)
    // ============================================================
    (function() {
      var s = document.createElement('script');
      s.async = true;
      s.src = '//cdn.busuanzi.cc/busuanzi/3.6.9/busuanzi.min.js';
      s.onerror = function() {
        ['busuanzi_site_pv','busuanzi_site_uv','busuanzi_today_pv'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.textContent = '?';
        });
      };
      document.head.appendChild(s);
    })();


    //  CONFIGURATION — 板块/概念/个股代码映射

    // ============================================================

    const SECTOR_REPRESENTATIVES = {

      '银行': ['sh601398', 'sh601939', 'sh601288', 'sz000001'],

      '证券': ['sh601688', 'sh600030', 'sz000776', 'sh601211'],

      '保险': ['sh601318', 'sh601601', 'sh601336'],

      '房地产': ['sz000002', 'sz001979', 'sz000069'],

      '新能源': ['sz300750', 'sz002594', 'sz300274'],

      '半导体': ['sh688981', 'sz002371', 'sz002049'],

      '医药': ['sz300760', 'sz300122', 'sh600276'],

      '食品饮料': ['sh600519', 'sz000858', 'sh600887'],

      '汽车': ['sh600104', 'sz002594', 'sh601238'],

      '电子': ['sz000725', 'sz002241', 'sz002475'],

      '计算机': ['sz002415', 'sz300059', 'sh600588'],

      '传媒': ['sz300433', 'sz002439', 'sz000917'],

      '煤炭': ['sh601088', 'sz000983', 'sh601225'],

      '钢铁': ['sh600019', 'sh601003', 'sz000708'],

      '电力': ['sh600900', 'sh601985', 'sh600011'],

    };


    const CONCEPT_CODES = {

      '人工智能': ['sz002230', 'sz002405', 'sh688787', 'sz300677', 'sz300561'],

      '机器人': ['sz002747', 'sz300124', 'sh603019', 'sz300282', 'sz300024'],

      '锂电池': ['sz002466', 'sz002460', 'sz300037', 'sz300014', 'sz002812'],

      '光伏': ['sh601012', 'sz002459', 'sh688599', 'sz002610', 'sz300118'],

      '5G通信': ['sz000063', 'sz002475', 'sh600487', 'sz300498', 'sh600498'],

      '芯片': ['sh688981', 'sz002371', 'sz002049', 'sz688396', 'sh688008'],

      '新能源汽车': ['sz002594', 'sh600418', 'sz002466', 'sh600733', 'sz300124'],

      '半导体': ['sz002371', 'sh688981', 'sz002049', 'sz688396', 'sz688396'],

      '数字经济': ['sz300059', 'sz002415', 'sh600588', 'sz300468', 'sz002197'],

      '医药创新': ['sz300760', 'sz300122', 'sh600276', 'sz002653', 'sh600518'],

      '元宇宙': ['sz300467', 'sz300459', 'sz002292', 'sz300264', 'sh600637'],

      '军工': ['sh600893', 'sz002013', 'sh600038', 'sz300696', 'sh600316'],

    };


    // ============================================================

    //  DATA FETCHING — 通过 script[charset=gbk] 标签加载腾讯API

    //  腾讯API返回 JavaScript 代码: v_sh601398="1~工商银行~..."

    //  script 标签不受 CORS 限制，浏览器直连

    // ============================================================

    let _fetchCounter = 0;


    function fetchTencentData(codes) {

      return new Promise((resolve, reject) => {

        const batchId = 'tcb_' + (++_fetchCounter) + '_' + Date.now();

        const script = document.createElement('script');

        script.charset = 'gbk';

        script.id = batchId;

        script.src = 'https://qt.gtimg.cn/q=' + codes.join(',');


        const timeout = setTimeout(() => {

          cleanup();

          reject(new Error('Timeout'));

        }, 10000);


        function cleanup() {

          clearTimeout(timeout);

          if (script.parentNode) script.parentNode.removeChild(script);

        }


        script.onload = () => {

          const results = {};

          codes.forEach(code => {

            const varName = 'v_' + code;

            if (window[varName] !== undefined && window[varName] !== '') {

              results[code] = window[varName];

            }

            // Clean up global variable

            delete window[varName];

          });

          cleanup();

          resolve(results);

        };


        script.onerror = () => {

          cleanup();

          reject(new Error('Network error'));

        };


        document.head.appendChild(script);

      });

    }


    // ============================================================

    //  DATA PARSING — 解析腾讯API数据格式

    //  格式: "1~名称~代码~现价~昨收~...~成交量~...~日期~...~最高~最低"

    // ============================================================

    function parseStockData(rawData) {

      const result = {};

      for (const [code, dataStr] of Object.entries(rawData)) {

        const parts = dataStr.split('~');

        if (parts.length >= 35) {

          try {

            const name = (parts[1] || '').trim();

            const stockCode = (parts[2] || '').trim();

            const price = parseFloat(parts[3]) || 0;

            const yesterday = parseFloat(parts[4]) || price;

            const volume = parseInt(parts[6]) || 0;

            const change = yesterday > 0 ? Math.round((price - yesterday) / yesterday * 10000) / 100 : 0;

            const high = parseFloat(parts[33]) || price;

            const low = parseFloat(parts[34]) || price;

            const tradeDate = parts[30] || '';


            if (name && price > 0) {

              result[code] = {

                name, code: stockCode, price, yesterday, change, volume, high, low,

                date: tradeDate.substring(0, 8)

              };

            }

          } catch (e) { /* skip malformed entries */ }

        }

      }

      return result;

    }


    // ============================================================

    //  DATA PROCESSING — 板块/概念/个股数据处理

    // ============================================================

    function processSectors(stockData) {

      const sectors = [];

      for (const [sectorName, codes] of Object.entries(SECTOR_REPRESENTATIVES)) {

        const stocks = codes.map(c => stockData[c]).filter(Boolean);

        if (stocks.length > 0) {

          const avgChange = stocks.reduce((sum, s) => sum + s.change, 0) / stocks.length;

          const totalVolume = stocks.reduce((sum, s) => sum + s.volume, 0);

          sectors.push({

            name: sectorName,

            change: Math.round(avgChange * 100) / 100,

            price: Math.round(stocks[0].price * 100) / 100,

            volume: totalVolume,

            heat: Math.min(100, Math.max(20, 50 + Math.abs(avgChange) * 3)),

            link: 'https://www.baidu.com/s?wd=' + encodeURIComponent(sectorName + '板块')

          });

        }

      }

      sectors.sort((a, b) => Math.abs(b.change) - Math.abs(a.change));

      return sectors;

    }

    const SECTOR_SUFFIXES = {

