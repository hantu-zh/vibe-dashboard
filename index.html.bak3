      (function() {
        var root = document.getElementById('etf-root');
        if (!root) return;
        var panel = root.closest('.etf-panel');
        
        function initETF() {
          var el = document.getElementById('etf-embed');
          if (!el || !el.textContent) { setTimeout(initETF, 500); return; }
          var data;
          try { data = JSON.parse(el.textContent); } catch(e) { setTimeout(initETF, 500); return; }
          
          if (!data || !data.etfs || !data.etfs.length) return;
          
          // Category structure
          var cats = { '宽基': [], '行业': [], '主题': [] };
          // Sub-category for 行业
          var subCats = ['科技', '金融', '医药', '消费', '新能源', '军工', '周期', '其他'];
          var industrySub = {};
          subCats.forEach(function(s) { industrySub[s] = []; });
          industrySub['其他'] = [];
          
          data.etfs.forEach(function(etf) {
            var cat = etf.category || '主题';
            if (cats[cat]) {
              cats[cat].push(etf);
            } else {
              cats['主题'].push(etf);
            }
            if (cat === '行业') {
              var sub = etf.sub_category || '其他';
              if (industrySub[sub]) {
                industrySub[sub].push(etf);
              } else {
                industrySub['其他'].push(etf);
              }
            }
          });
          
          // Stars rendering
          function renderStars(n) {
            var full = '★'.repeat(Math.min(n, 5));
            return '<span class="etf-stars">' + full + '</span>';
          }
          
          // Render table
          function renderTable(etfs, catIdx, subIdx) {
            var h = '<table><tr>';
            h += '<th>代码</th>';
            h += '<th onclick="etfSort(' + catIdx + ',' + subIdx + ',1)">名称</th>';
            h += '<th onclick="etfSort(' + catIdx + ',' + subIdx + ',2)">现价</th>';
            h += '<th onclick="etfSort(' + catIdx + ',' + subIdx + ',3)">涨跌幅</th>';
            h += '<th onclick="etfSort(' + catIdx + ',' + subIdx + ',4)">成交额</th>';
            h += '<th>评分</th></tr>';
            etfs.forEach(function(e) {
              var chgClass = (e.change_pct || 0) >= 0 ? 'etf-up' : 'etf-down';
              var chgSign = (e.change_pct || 0) >= 0 ? '+' : '';
              h += '<tr>';
              h += '<td>' + e.code + '</td>';
              h += '<td><a href="https://quote.eastmoney.com/' + e.full_code + '.html" target="_blank">' + e.name + '</a></td>';
              h += '<td>' + e.price + '</td>';
              h += '<td class="' + chgClass + '">' + chgSign + (e.change_pct || 0).toFixed(2) + '%</td>';
              h += '<td>' + (e.volume || '-') + '</td>';
              h += '<td>' + renderStars(e.stars || 0) + '</td>';
              h += '</tr>';
            });
            h += '</table>';
            return h;
          }
          
          // Setup sorting
          window.etfSort = function(catIdx, subIdx, col) {
            var key = catIdx + '-' + subIdx + '-' + col;
            if (!window._etfSort) window._etfSort = {};
            var dir = window._etfSort[key] === 'asc' ? 'desc' : 'asc';
            window._etfSort[key] = dir;
            
            var tbl = document.querySelector('#etf-pages table');
            if (!tbl) return;
            var tbody = tbl.tBodies[0] || tbl;
            var rows = Array.from(tbody.rows);
            rows.sort(function(a, b) {
              var va = a.cells[col].innerText.trim();
              var vb = b.cells[col].innerText.trim();
              if (col === 0 || col === 1) return dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
              if (col === 4) {
                // Volume: parse with 万/亿
                va = parseVolume(va); vb = parseVolume(vb);
              } else {
                va = parseFloat(va) || 0;
                vb = parseFloat(vb) || 0;
              }
              return dir === 'asc' ? va - vb : vb - va;
            });
            rows.forEach(function(r) { tbody.appendChild(r); });
          };
          
          function parseVolume(s) {
            s = s.trim();
            if (s.indexOf('亿') > -1) return parseFloat(s) * 10000;
            if (s.indexOf('万') > -1) return parseFloat(s);
            return parseFloat(s) || 0;
          }
          
          // Build UI
          var catKeys = ['宽基', '行业', '主题'];
          var catLabels = ['宽基(' + cats['宽基'].length + ')', '行业(' + cats['行业'].length + ')', '主题(' + cats['主题'].length + ')'];
          
          // Meta
          root.querySelector('.etf-meta').textContent = '生成时间: ' + (data.generated_at || '') + ' | 共 ' + data.etfs.length + ' 只ETF | 点击列头排序';
          
          // Tabs
          var tabContainer = root.querySelector('.etf-tabs');
          catKeys.forEach(function(k, i) {
            var btn = document.createElement('button');
            btn.className = 'etf-tab' + (i === 0 ? ' active' : '');
            btn.textContent = catLabels[i];
            btn.onclick = function() { showPage(i); };
            tabContainer.appendChild(btn);
          });
          
          // Pages container
          var pagesEl = document.getElementById('etf-pages');
          
          function showPage(idx) {
            // Update tabs
            var tabs = tabContainer.querySelectorAll('.etf-tab');
            tabs.forEach(function(t, i) { t.classList.toggle('active', i === idx); });
            
            var html = '';
            var catKey = catKeys[idx];
            var catEtfs = cats[catKey];
            
            if (catKey === '行业') {
              // Industry has subtabs
              html += '<div class="etf-subtabs" style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;justify-content:center;">';
              subCats.forEach(function(sc, si) {
                var scList = industrySub[sc] || [];
                if (scList.length > 0) {
                  html += '<button class="etf-subtab' + (si === 0 ? ' active' : '') + '" onclick="etfShowSub(' + idx + ',' + si + ')">' + sc + '(' + scList.length + ')</button>';
                }
              });
              html += '</div>';
              
              // First subcategory
              var firstSub = subCats.filter(function(s) { return (industrySub[s] || []).length > 0; });
              var curSub = firstSub[0] || '科技';
              html += '<div id="etf-subpage-0">' + renderTable(industrySub[curSub] || [], idx, 0) + '</div>';
            } else {
              html += '<div id="etf-subpage-0">' + renderTable(catEtfs, idx, 0) + '</div>';
            }
            
            pagesEl.innerHTML = html;
          }
          
          // Sub-tab switching
          window.etfShowSub = function(catIdx, subIdx) {
            var subBtns = pagesEl.querySelectorAll('.etf-subtab');
            subBtns.forEach(function(b, i) { b.classList.toggle('active', i === subIdx); });
            
            var catKey = catKeys[catIdx];
            var sc = subCats[subIdx];
            var etfList = industrySub[sc] || [];
            pagesEl.innerHTML = pagesEl.innerHTML; // just update but we need to rebuild
            // Rebuild subpage section
            var html = '<div class="etf-subtabs" style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;justify-content:center;">';
            subCats.forEach(function(sc2, si2) {
              var scList2 = industrySub[sc2] || [];
              if (scList2.length > 0) {
                html += '<button class="etf-subtab' + (si2 === subIdx ? ' active' : '') + '" onclick="etfShowSub(' + catIdx + ',' + si2 + ')">' + sc2 + '(' + scList2.length + ')</button>';
              }
            });
            html += '</div>';
            html += '<div id="etf-subpage-0">' + renderTable(etfList, catIdx, subIdx) + '</div>';
            pagesEl.innerHTML = html;
          };
          
          // Show first page
          showPage(0);
          
          // Expand on click
          if (panel) {
            panel.addEventListener('click', function() {
              this.classList.toggle('expanded');
            });
          }
        }
        
        initETF();
      })();
      </script>
    </section>

