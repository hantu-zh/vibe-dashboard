      <!-- MODULE: etf-panel -->
    <!-- MODULE: etf_panel -->
    <section class="card etf-panel" style="grid-column: 1 / -1;">
      <h2 class="card-title">📊 ETF市场雷达</h2>
      <div id="etf-root">
        <div class="etf-meta" style="color:#666;font-size:0.8em;margin-bottom:10px;text-align:center;"></div>
        <div class="etf-tabs" style="display:flex;gap:8px;margin-bottom:10px;justify-content:center;"></div>
        <div id="etf-pages"></div>
      </div>

      <style>
      .etf-panel { max-height: 450px; overflow: hidden; position: relative; }
      .etf-panel::after { content: '▼ 展开查看全部ETF'; position: absolute; bottom: 0; left: 0; right: 0; text-align: center; padding: 6px; background: linear-gradient(transparent, #0a0a1a); color: #00e5ff; font-size: 0.8em; cursor: pointer; pointer-events: none; }
      .etf-panel.expanded { max-height: none; }
      .etf-panel.expanded::after { display: none; }
      #etf-root { width: 100%; }
      #etf-root .etf-tab { padding: 6px 18px; border: none; border-radius: 16px; background: #1a1a3e; color: #888; cursor: pointer; font-size: 0.85em; transition: all .2s; }
      #etf-root .etf-tab:hover { background: #2a2a5e; color: #ccc; }
      #etf-root .etf-tab.active { background: #00e5ff; color: #0a0a1a; font-weight: bold; }
      #etf-root .etf-subtab { padding: 4px 12px; border: none; border-radius: 14px; background: #14142e; color: #888; cursor: pointer; font-size: 0.8em; transition: all .2s; }
      #etf-root .etf-subtab:hover { background: #1e1e4e; color: #ccc; }
      #etf-root .etf-subtab.active { background: #1a3a5e; color: #00e5ff; font-weight: bold; }
      #etf-root .etf-stars { color: #ffd740; font-size: 1em; letter-spacing: 1px; }
      #etf-root .etf-up { color: #ff5252; font-weight: bold; }
      #etf-root .etf-down { color: #00e676; font-weight: bold; }
      #etf-root table { width: 100%; border-collapse: collapse; font-size: 0.85em; }
      #etf-root th { background: #1a1a3e; color: #00e5ff; padding: 8px 6px; text-align: left; cursor: pointer; user-select: none; font-size: 0.85em; position: sticky; top: 0; }
      #etf-root th:hover { color: #40ffff; }
      #etf-root td { padding: 7px 6px; border-bottom: 1px solid #1a1a3e; }
      #etf-root tr:last-child td { border-bottom: none; }
      #etf-pages { padding-bottom: 8px; }
      #etf-root table::after { content: ''; display: block; height: 16px; }
      #etf-root tr:hover { background: #14142e; }
      #etf-root td a { color: #e0e0e0; text-decoration: none; }
      #etf-root td a:hover { color: #00e5ff; text-decoration: underline; }
      @media (max-width: 600px) {
        #etf-root table { font-size: 0.75em; }
        #etf-root th, #etf-root td { padding: 5px 4px; }
        #etf-root .etf-stars { font-size: 0.85em; }
      }
      /* Expand on click */
      .etf-panel.collapsed { max-height: 400px; }
      .etf-panel.collapsed::after { display: block; }
      </style>

