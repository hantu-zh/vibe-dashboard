    }
    .sector-name-cell a.sector-link:hover { color: #00e5cc; text-shadow: 0 0 8px #00e5cc; }
    .change-cell { font-weight: 600; font-size: 0.78rem; white-space: nowrap; letter-spacing: -0.3px; }
    .str-cell { min-width: 110px; }

    /* STR条 - 鱼骨渐变（行业板块） */
    .str-bar-fishbone {
      position: relative;
      height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.05);
      overflow: hidden;
      flex: 1;
      min-width: 100px;
    }
    .str-bar-fishbone .rps-fill {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      height: 100%;
      border-radius: 3px;
      box-shadow: 0 0 10px currentColor;
    }
    .str-bar-fishbone.up .rps-fill {
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(255,0,40,0.2) 20%,
        rgba(255,0,40,1) 50%,
        rgba(255,0,40,0.2) 80%,
        transparent 100%
      );
    }
    .str-bar-fishbone.down .rps-fill {
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(168,242,1,0.2) 20%,
        rgba(168,242,1,1) 50%,
        rgba(168,242,1,0.2) 80%,
        transparent 100%
      );
    }

    /* STR条 - 单侧渐变（概念板块） */
    .str-bar-single {
      position: relative;
      height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.05);
      overflow: hidden;
      flex: 1;
      min-width: 100px;
    }
    .str-bar-single .rps-fill {
      position: absolute;
      left: 0;
      height: 100%;
      border-radius: 3px;
      box-shadow: 0 0 10px currentColor;
    }
    .str-bar-single.up .rps-fill {
      background: linear-gradient(90deg,
        rgba(255,0,146,1) 0%,
        rgba(255,0,146,0.6) 40%,
        rgba(255,0,146,0.2) 80%,
        transparent 100%
      );
    }
    .str-bar-single.down .rps-fill {
      background: linear-gradient(90deg,
        rgba(121,134,203,1) 0%,
        rgba(121,134,203,0.6) 40%,
        rgba(121,134,203,0.2) 80%,
        transparent 100%
      );
    }

    /* STR条动画效果 - 行业(闪烁) */
    /* 行业板块STR条 - 无动画 */
    .str-bar-fishbone .rps-fill {
      /* 静态显示，无动画 */
    }

    @keyframes str-shimmer {
      0% { opacity: 0.7; filter: brightness(1); }
      50% { opacity: 1; filter: brightness(1.3); }
      100% { opacity: 0.7; filter: brightness(1); }
    }

    /* STR条动画效果 - 概念(光流动) */
    .str-bar-single {
      position: relative;
      overflow: hidden;
    }
    .str-bar-single .rps-fill::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(255,255,255,0.32) 50%,
        transparent 100%
      );
      animation: str-light-flow 4s linear infinite;
    }
    @keyframes str-light-flow {
      0% { left: -100%; }
      100% { left: 100%; }
    }

    .rps-bar {
      width: 100%;
      height: 5px;
      background: rgba(255,255,255,0.07);
