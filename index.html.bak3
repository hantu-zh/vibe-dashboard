    // ============================================================
    //  每日选股 — 从 daily_picks.json 加载定时任务选股结果
    // ============================================================
    //  loadDailyPicks — 加载 daily_picks.json 后用腾讯API刷新实时价格
    // ============================================================
    async function loadDailyPicks() { console.log("[VIBE] START loadDailyPicks");

      try {

        const now = new Date();
        const todayStr = localDateStr(now);
        const hour = now.getHours();
        const weekday = now.getDay();

        // 交易日判断：周末(5,6)或工作日上午7点前，使用上一个交易日
        const isWeekend = (weekday === 0 || weekday === 6);
        const isEarly = (hour < 7);

        // 优先级: 1)embedded 2)daily_picks.json 3)vibe_server API
        // GitHub Pages: daily_picks.json 可能时区错误状态，必需嵌入工作

        let data = null;
        console.log('[VIBE] Looking for date:', todayStr);

        // 1. Embedded (most reliable on GitHub Pages)
        try {
          const embedEl = document.getElementById('daily-picks-embed');
          if (embedEl) {
            const _ec = embedEl.textContent.trim();
            console.log('[VIBE-EMBED] length:', _ec.length, '| preview:', _ec.substring(0,80).replace(/\n/g,' '));
            if (_ec) {
              data = JSON.parse(_ec);
              console.log('[VIBE] Loaded embedded, top keys:', Object.keys(data), '| hasToday:', todayStr in data);
            }
          }
        } catch(e_emb) { console.error('[VIBE-EMBED] error:', e_emb.message); }

        // 2. daily_picks.json (may be stale on GitHub Pages - only use if has today key)
        if (!data || !(todayStr in data)) {
          try {
            const resp2 = await fetch('daily_picks.json', { cache: 'no-store' });
            if (resp2.ok) {
              const tmp = await resp2.json();
              console.log('[VIBE-FILE] keys:', Object.keys(tmp), '| hasToday:', todayStr in tmp);
              if (todayStr in tmp) { data = tmp; console.log('[VIBE] Using daily_picks.json'); }
              else { console.log('[VIBE] daily_picks.json stale, keeping embedded'); }
            }
          } catch(e2) { console.log('[VIBE-FILE] unavailable:', e2.message); }
        }

        // 3. vibe_server API (local only)
        if (!data || !(todayStr in data)) {
          try {
            const resp = await fetch('/api/daily_picks', { cache: 'no-store' });
            if (resp.ok) { data = await resp.json(); console.log('[VIBE] Loaded from /api/daily_picks'); }
          } catch(e1) { console.log('[VIBE-API] unavailable:', e1.message); }
        }

        if (!data) { console.error('[VIBE] All sources failed!'); return null; }
        window._dailyPicksData = data;
        console.log("[VIBE] Data loaded, keys:", Object.keys(data), "| hasToday:", todayStr in data);

        console.log('[VIBE] todayStr:', todayStr, 'isWeekend:', isWeekend, 'isEarly:', isEarly);
        const _allKeys = Object.keys(data);
        console.log('[VIBE] All date keys:', _allKeys);
        
        // 交易日判断：周末或工作日上午7点前，使用上一个交易日
        let targetDate = todayStr;
        
// ============================================================
// NORMALIZE daily_picks.json format
// JSON: {"2026-04-28": {"任务": {"time","count","picks":[...]}}}
// After normalization: {"任务": [{...stock...}]}  (flat, date-level removed)
// ============================================================
(function() {
  const _keys = Object.keys(data || {});
  const _hasDateKeys = _keys.some(k => /^\d{4}-\d{2}-\d{2}$/.test(k));
  if (_hasDateKeys) {
    const _dates = _keys.filter(k => /^\d{4}-\d{2}-\d{2}$/.test(k)).sort().reverse();
    const _nonStockTasks = ['xueqiu_7x24','weekend_review','sector_rankings','candidates','count','generated_at'];
    let _bestDate = null;
    for (const d of _dates) {
      if (d <= todayStr) {
        const _tasks = Object.keys(data[d] || {});
        const _stockTasks = _tasks.filter(t => !_nonStockTasks.includes(t));
        if (_stockTasks.length > 0) { _bestDate = d; break; }
      }
    }
    if (_bestDate && data[_bestDate]) {
      const _origData = data; // save original before overwriting
      const _raw = data[_bestDate];
      data = {};
      for (const [tk, tv] of Object.entries(_raw)) {
        if (tv && tv.picks && Array.isArray(tv.picks)) data[tk] = { time: tv.time || '', picks: tv.picks, _date: _bestDate };
        else if (Array.isArray(tv)) data[tk] = { time: '', picks: tv, _date: _bestDate };
      }
      // Fallback: fill missing tasks from earlier dates (e.g. holidays)
      const _filledDates = [_bestDate];
      for (const d of _dates) {
        if (d >= _bestDate) continue;
        const _prevRaw = _origData[d] || {}; // use original data
        const _prevTasks = Object.keys(_prevRaw);
        const _prevStockTasks = _prevTasks.filter(t => !_nonStockTasks.includes(t));
        for (const tk of _prevStockTasks) {
          if (!(tk in data)) {
            const tv = _prevRaw[tk];
            if (tv && tv.picks && Array.isArray(tv.picks) && tv.picks.length > 0) {
              data[tk] = { time: tv.time || '', picks: tv.picks, _date: d };
              _filledDates.push(d);
              console.log('[VIBE] Fallback task: ' + tk + ' from ' + d);
            }
          }
        }
        if (_filledDates.length > 5) break; // safety limit
      }
      console.log('[VIBE] Normalized: bestDate=' + _bestDate + ', tasks=' + Object.keys(data).length + ', fallbackDates=' + _filledDates.filter(x=>x!==_bestDate).join(','));
    }
  }
})();
const hasValidData = (dt) => data[dt] && Object.keys(data[dt]).length > 0;
        // Data is flat (normalized by IIFE above), no date lookup needed
        if (isWeekend || isEarly) {
          console.log('[VIBE] Weekend/early:', todayStr);
        }

        const todayData = data;

        if (!todayData) return null;


        // Collect all stock codes from all strategies

        const allCodes = new Set();

        // Dynamic task order from TASK_SCHEDULE + actual data keys
        const scheduledNames = TASK_SCHEDULE.map(t => t.name);
        const dataTaskNames = Object.keys(todayData);
        const taskOrder = [...new Set([...scheduledNames, ...dataTaskNames])];

        for (const task of taskOrder) {

          const taskData = todayData[task];
          const picks = taskData && taskData.picks ? taskData.picks : (Array.isArray(taskData) ? taskData : null);

          if (picks && Array.isArray(picks)) {

            for (const p of picks) {

              if (p.code) {

                const prefix = p.code.startsWith('6') ? 'sh' : 'sz';

                allCodes.add(prefix + p.code);

              }

            }

          }

        }


        // Fetch real-time prices from Tencent API

        if (allCodes.size > 0) {

          try {

            const codeList = [...allCodes];

            console.log('[VIBE] Fetching real-time prices for', codeList.length, 'stocks');

            const raw = await fetchTencentData(codeList);

            const parsed = parseStockData(raw);


            // Build a lookup: '600398' -> {price, change, ...}

            const priceLookup = {};

            for (const [tencentCode, info] of Object.entries(parsed)) {

              priceLookup[info.code] = info;  // info.code is the 6-digit code

            }


            // Overwrite price/change in todayData with real-time data

            for (const task of taskOrder) {

              const taskData = todayData[task];
              const picks = taskData && taskData.picks ? taskData.picks : (Array.isArray(taskData) ? taskData : null);

          if (picks && Array.isArray(picks)) {

                for (const p of picks) {

                  const rt = priceLookup[p.code];

                  if (rt) {

                    p.price = rt.price;

                    p.change = rt.change;

                    p._realtime = true;

                  }

                }

              }

            }

            console.log('[VIBE] Real-time prices updated for', Object.keys(priceLookup).length, 'stocks');

          } catch (e) {

            console.warn('[VIBE] Real-time price fetch failed, using daily_picks data:', e);

          }

        }


        console.log('[VIBE] targetDate:', targetDate, 'taskOrder:', taskOrder);
        return todayData;

      } catch (e) {

        console.warn('[VIBE] loadDailyPicks failed:', e);

        return null;

      }

    }


    function processStocks() {
      // Returns a Promise — caller handles async
      return loadDailyPicks().then(todayData => {
        if (!todayData) { console.error('[VIBE] processStocks: todayData is null, returning []'); return []; }

        const now = new Date();
        const currentHour = now.getHours();
        const currentMinute = now.getMinutes();
        const currentTimeStr = currentHour * 60 + currentMinute; // minutes since midnight

        const result = [];

        // Build task order from TASK_SCHEDULE (scheduled) + any extra tasks in data
        const scheduledNames = TASK_SCHEDULE.map(t => t.name);
        const dataTaskNames = Object.keys(todayData);
        const taskOrder = [...new Set([...scheduledNames, ...dataTaskNames])];

        for (const task of taskOrder) {
          const taskData = todayData[task];
          const picks = taskData && taskData.picks ? taskData.picks : (Array.isArray(taskData) ? taskData : null);
          const taskTime = taskData && taskData.time ? taskData.time : '';
          const taskDate = taskData && taskData._date ? taskData._date : '';

          // Get expected time from schedule
          const schedule = TASK_SCHEDULE.find(s => s.name === task);
          const expectedTime = schedule ? schedule.expectedTime : null;

          // Check if task should have run by now (compare expected time with current time)
          let status = 'ok';
          let delayMinutes = 0;

          if (expectedTime) {
            const [expHour, expMin] = expectedTime.split(':').map(Number);
            const expectedMinutes = expHour * 60 + expMin;
            const timeDiff = currentTimeStr - expectedMinutes;

            if (!picks || picks.length === 0) {
              // No data yet
              if (timeDiff > 30) {
                status = 'delayed'; // More than 30 min late
                delayMinutes = timeDiff;
              } else if (timeDiff > 0) {
                status = 'waiting'; // Still within tolerance
              } else {
                status = 'pending'; // Not yet scheduled
              }
            }
          }

          if (picks && Array.isArray(picks) && picks.length > 0) {
            result.push({ task, time: taskTime, picks: picks.slice(0, 10), status, expectedTime, date: taskDate });
          } else {
            // Show empty task with status
            result.push({ task, time: taskTime, picks: [], status, expectedTime, delayMinutes, date: taskDate });
          }
        }

        return result;
      });
    }


    function updateStocks(stockGroups) {
      // 过滤掉 追涨强势股 和 美股 — 已有专属面板
      const filtered = stockGroups.filter(g => !g.task || (!g.task.includes('追涨强势股') && !g.task.includes('美股')));
      const list = document.getElementById('stock-list');

      if (!filtered || filtered.length === 0) {
        list.innerHTML = '<div class="error-msg">今日暂无选股记录</div>';
        return;
      }

      const newStockHtml = filtered.map(g => {
        const isEmpty = !g.picks || g.picks.length === 0;
        const sectionClass = isEmpty ? 'picks-section picks-section-empty' : 'picks-section';
        const scheduleTag = g.expectedTime ? `<span class="picks-schedule">计划${g.expectedTime}</span>` : '';

        // Status tags
        let statusTag = '';
        if (g.status === 'delayed') {
          statusTag = `<span class="picks-delay">⏰ 延时${g.delayMinutes}分钟</span>`;
        } else if (g.status === 'waiting') {
          statusTag = `<span class="picks-delay">⏳ 执行中</span>`;
        } else if (g.status === 'pending') {
          statusTag = `<span class="picks-schedule">待执行</span>`;
        }

        let bodyHtml = '';
        if (isEmpty) {
          if (g.status === 'delayed') {
            bodyHtml = '<div class="picks-empty">⚠️ 超时未选出股票</div>';
          } else if (g.status === 'waiting') {
            bodyHtml = '<div class="picks-waiting">⏳ 任务执行中，请稍后刷新...</div>';
          } else if (g.status === 'pending') {
            bodyHtml = '<div class="picks-waiting">📋 定时任务尚未到执行时间</div>';
          } else {
            bodyHtml = '<div class="picks-empty">未选出符合条件的股票</div>';
          }
        } else {
          bodyHtml = g.picks.filter(p => p && p.code).map((p, i) => {
            const price = typeof p.price === 'number' ? p.price : parseFloat(p.price);
            const change = typeof p.change === 'number' ? p.change : parseFloat(p.change);
            const color = change >= 0 ? 'var(--neon-red)' : 'var(--neon-green)';
            const sign = change >= 0 ? '+' : '';
            const rtTag = p._realtime ? ' <span style="font-size:0.65rem;color:var(--neon-cyan);">实时</span>' : '';
            const prefix = p.code.startsWith('6') ? 'sh' : 'sz';
            return `
              <div class="picks-row">
                <span class="picks-code">${p.code} ${p.name}</span>
                <span class="picks-price">¥${isNaN(price) ? '-' : price.toFixed(2)}</span>
                <span class="picks-change" style="color:${color}">${sign}${isNaN(change) ? '-' : change.toFixed(2)}%</span>
                ${p.level ? `<span class="picks-level">${p.level}</span>` : ''}
                ${rtTag}
                <a class="picks-link" href="https://quote.eastmoney.com/${prefix}${p.code}.html" target="_blank" title="东方财富行情">📈</a>
              </div>`;
          }).join('');
        }

        const countTag = isEmpty ? '' : `<span class="picks-count">${g.picks.length}只</span>`;
        const timeTag = g.time ? `<span class="picks-time">${g.time}</span>` : '';

        return `
          <div class="${sectionClass}">
            <div class="picks-header">【${g.task}】${countTag}${timeTag}${scheduleTag}${statusTag}</div>
            ${bodyHtml}
          </div>`;
      }).join('');
      // Anti-flicker: only update DOM if content changed
      if (list.dataset.lastHtml !== newStockHtml) {
        list.dataset.lastHtml = newStockHtml;
        list.innerHTML = newStockHtml;
      }
    
      
      // 新增：渲染"追涨强势股"到独立容器
      const chaseList = document.getElementById('chase-strong-stocks-list');
      if (chaseList) {
        const chaseGroups = stockGroups.filter(g => g.task && g.task.includes('追涨强势股') && g.picks && g.picks.length > 0);
        // Sort by time slot: 10:00 -> 12:00 -> 14:00
        chaseGroups.sort((a, b) => {
          const timeA = a.task.match(/\d{2}:\d{2}/)?.[0] || a.time || '99:99';
          const timeB = b.task.match(/\d{2}:\d{2}/)?.[0] || b.time || '99:99';
          return timeA.localeCompare(timeB);
        });
        if (chaseGroups.length > 0) {
          const chaseHtml = chaseGroups.map(g => {
            const isEmpty = !g.picks || g.picks.length === 0;
            const sectionClass = isEmpty ? 'picks-section picks-section-empty' : 'picks-section';
            let bodyHtml = '';
            if (isEmpty) {
              bodyHtml = '<div class="picks-waiting">暂无数据</div>';
            } else {
              bodyHtml = g.picks.map(p => {
                const price = typeof p.price === 'number' ? p.price : parseFloat(p.price);
                const _rawCh = p.change || p.change_pct;
              const change = typeof _rawCh === 'number' ? _rawCh : parseFloat(_rawCh);
                const color = change >= 0 ? 'var(--neon-red)' : 'var(--neon-green)';
                const sign = change >= 0 ? '+' : '';
                const prefix = p.code.startsWith('6') ? 'sh' : 'sz';
                return `
                  <div class="picks-row">
                    <span class="picks-code">${p.code} ${p.name}</span>
                    <span class="picks-price">¥${isNaN(price) ? '-' : price.toFixed(2)}</span>
                    <span class="picks-change" style="color:${color}">${sign}${isNaN(change) ? '-' : change.toFixed(2)}%</span>
                    ${p.level ? `<span class="picks-level">${p.level}</span>` : ''}
                    <a class="picks-link" href="https://quote.eastmoney.com/${prefix}${p.code}.html" target="_blank" title="东方财富行情">📈</a>
                  </div>
                `;
              }).join('');
            }
            return `
              <div class="${sectionClass}">
                <div class="picks-header">【追涨强势股】<span class="picks-count">${g.picks.length}只</span>${g.date && g.date !== localDateStr() ? '<span class="picks-date" style="color:var(--neon-yellow);font-size:0.85em;margin-left:6px">(' + g.date + ')</span>' : ''}<span class="picks-time">${g.time || '--:--'}</span></div>
                ${bodyHtml}
              </div>
            `;
          }).join('');
          chaseList.innerHTML = chaseHtml;
        } else {
          chaseList.innerHTML = '<div class="picks-waiting">暂无追涨强势股数据</div>';
        }
      }

    }

    // US Stock Picks - 高欣选股美股版
    async function loadUSPicks() {
      console.log("[VIBE] Loading US stock picks...");
      const list = document.getElementById('us-stock-list');
      if (!list) return;
      try {
        // 1. Try to load from embed
        const embedEl = document.getElementById('us-picks-embed');
        let data = null;
        if (embedEl) {
          try { data = JSON.parse(embedEl.textContent); }
          catch (e) { console.warn('[VIBE] us-picks-embed parse failed'); }
        }
        
        // 2. Try to load from external JSON
        if (!data) {
          const resp = await fetch('us_picks.json', { cache: 'no-store' });
          if (resp.ok) { data = await resp.json(); }
        }
        
        if (!data) {
          list.innerHTML = '<div class="error-msg">暂无美股数据</div>';
          return;
        }
        
        renderUSPicks(data, list);
      } catch (e) {
        console.error('[VIBE] loadUSPicks error:', e);
        list.innerHTML = '<div class="error-msg">加载失败</div>';
      }
    }

    function calcPEG(fpe, growth) {
      if (!fpe || fpe <= 0 || !growth || growth <= 0) return '-';
      return (fpe / growth).toFixed(2);
    }
    function peStr(v) { return (v && v > 0) ? v.toFixed(1) : '-'; }
    function renderUSPicks(data, container) {
      const method1 = data.method1 || {};
      const method2 = data.method2 || {};
      const updateTime = data.time || '--:--';
      const updateDate = data.date || '';
      
      let html = '<div class="us-update-time">⛳ 每日10:00更新 | ' + (updateDate ? updateDate + ' ' : '') + updateTime + ' | v0.0.42</div>';
      
      // 方法1: 放量突破 — 11列
      if (method1.picks && method1.picks.length > 0) {
        html += `
        <div class="picks-section">
          <div class="picks-header us-picks-header">📈【${method1.name || '放量突破'}】<span class="picks-count">${method1.picks.length}只</span></div>
          <div class="us-table-wrap"><table class="us-table">
          <thead><tr><th>代码</th><th>名称</th><th>价格</th><th>涨幅</th><th>量比</th><th>均PE</th><th>静态</th><th>动态</th><th>PEG</th><th>板块</th><th>分</th></tr></thead>
          <tbody>${method1.picks.map(p => `<tr>
            <td class="us-code"><b><a href="https://quote.eastmoney.com/us/${p.symbol}.html" target="_blank" style="color:inherit;text-decoration:none;">${p.symbol||''}</a></b></td>
            <td>${p.name||''}</td>
            <td class="num">$${(parseFloat(p.price)||0).toFixed(2)}</td>
            <td class="num" style="color:${parseFloat(p.change)>=0?'var(--neon-red)':'var(--neon-green)'}">${parseFloat(p.change)>=0?'+':''}${(parseFloat(p.change)||0).toFixed(2)}%</td>
            <td class="num">${(p.vol_ratio||0).toFixed(1)}</td>
            <td class="num">${peStr(p.avgPE3yr)}</td>
            <td class="num">${peStr(p.trailingPE)}</td>
            <td class="num">${peStr(p.forwardPE)}</td>
            <td class="num">${calcPEG(p.forwardPE, p.earningsGrowth)}</td>
            <td>${p.sector||''}</td>
            <td class="num"><b>${(p.score||0).toFixed(0)}</b></td>
          </tr>`).join('')}</tbody>
          </table></div>
        </div>`;
      }
      
      // 方法2: 温和上涨 — 11列
      if (method2.picks && method2.picks.length > 0) {
        html += `
        <div class="picks-section">
          <div class="picks-header us-picks-header">📊【${method2.name || '温和上涨'}】<span class="picks-count">${method2.picks.length}只</span></div>
          <div class="us-table-wrap"><table class="us-table">
          <thead><tr><th>代码</th><th>名称</th><th>价格</th><th>3日涨幅</th><th>量比</th><th>均PE</th><th>静态</th><th>动态</th><th>PEG</th><th>板块</th><th>分</th></tr></thead>
          <tbody>${method2.picks.map(p => `<tr>
            <td class="us-code"><b><a href="https://quote.eastmoney.com/us/${p.symbol}.html" target="_blank" style="color:inherit;text-decoration:none;">${p.symbol||''}</a></b></td>
            <td>${p.name||''}</td>
            <td class="num">$${(parseFloat(p.price)||0).toFixed(2)}</td>
            <td class="num" style="color:${parseFloat(p.change_3d||p.change||0)>=0?'var(--neon-red)':'var(--neon-green)'}">${parseFloat(p.change_3d||p.change||0)>=0?'+':''}${(parseFloat(p.change_3d||p.change||0)).toFixed(2)}%</td>
            <td class="num">${(p.vol_ratio||0).toFixed(1)}</td>
            <td class="num">${peStr(p.avgPE3yr)}</td>
            <td class="num">${peStr(p.trailingPE)}</td>
            <td class="num">${peStr(p.forwardPE)}</td>
            <td class="num">${calcPEG(p.forwardPE, p.earningsGrowth)}</td>
            <td>${p.sector||''}</td>
            <td class="num"><b>${(p.score||0).toFixed(0)}</b></td>
          </tr>`).join('')}</tbody>
          </table></div>
        </div>`;
      }
      
      container.innerHTML = html || '<div class="error-msg">暂无推荐</div>';
    }

function processConcepts(stockData) {

      const concepts = [];

      for (const [conceptName, codes] of Object.entries(CONCEPT_CODES)) {

        const stocks = codes.map(c => stockData[c]).filter(Boolean);

        if (stocks.length > 0) {

          const avgChange = stocks.reduce((sum, s) => sum + s.change, 0) / stocks.length;

          concepts.push({

            name: conceptName,

            change: Math.round(avgChange * 100) / 100,

            heat: Math.min(100, Math.max(20, 50 + Math.abs(avgChange) * 2.5)),

            link: 'https://www.baidu.com/s?wd=' + encodeURIComponent(conceptName + '概念股')

          });

        }

      }

      concepts.sort((a, b) => Math.abs(b.change) - Math.abs(a.change));

      return concepts;

    }


    function calculateSentiment(sectors) {

      if (!sectors || sectors.length === 0) {

        return { bullish: 50, neutral: 30, bearish: 20, overall: 50 };

      }

      const up = sectors.filter(s => s.change > 0).length;

      const total = sectors.length;

      const ratio = up / total;


      const bullish = Math.min(70, Math.max(20, ratio * 100));

      const bearish = Math.min(50, Math.max(10, (1 - ratio) * 100));

      const neutral = 100 - bullish - bearish;


      return {

        bullish: Math.round(bullish * 10) / 10,

        neutral: Math.round(neutral * 10) / 10,

        bearish: Math.round(bearish * 10) / 10,

        overall: Math.round(bullish - bearish + 50)

      };

    }


    function generateAlerts(sectors) {

      const alerts = [];

      const now = new Date().toLocaleTimeString('zh-CN', { hour12: false });


      for (const s of sectors.slice(0, 5)) {

        if (s.change > 2) {

          alerts.push({ type: 'hot', title: `[HOT] ${s.name} +${s.change.toFixed(2)}%`, time: now });

        } else if (s.change < -1.5) {

          alerts.push({ type: 'warning', title: `[WARN] ${s.name} ${s.change.toFixed(2)}%`, time: now });

        }

      }


      return alerts.slice(0, 5);

    }


    // ============================================================

    //  SLOW RISE — 连续排名递进板块（慢热）

    //  使用 localStorage 存储历史排名

    // ============================================================

    const SLOWRISE_KEY = 'vibe_trend_history';


    function loadTrendHistory() {

      try {

        const data = localStorage.getItem(SLOWRISE_KEY);

        return data ? JSON.parse(data) : {};

      } catch { return {}; }

    }


    // Load pre-seeded history from server-side JSON (localStorage is empty for first-time visitors)

    async function loadTrendHistoryFromServer() {

      try {

        // 优先使用内置 SLOWRISE_SEED（页面自带最新完整数据）

        let serverData = {};

        if (typeof SLOWRISE_SEED !== 'undefined' && Object.keys(SLOWRISE_SEED).length > 0) {

          serverData = SLOWRISE_SEED;

          console.log('[SlowRise] Using built-in SLOWRISE_SEED:', Object.keys(serverData).length, 'days');

        } else {

          // 降级：从外部文件加载

          const resp = await fetch('vibe_trend_history.json');

          if (!resp.ok) return;

          serverData = await resp.json();

          console.log('[SlowRise] Using external JSON:', Object.keys(serverData).length, 'days');

        }

        const existing = loadTrendHistory();

        // Merge: server data as base, localStorage overwrites (more recent)

        // FIX: SLOWRISE_SEED 强制覆盖 localStorage，防止旧缓存污染
        const merged = { ...existing, ...serverData };

        // 确保合并后数据不比 SLOWRISE_SEED 少（防止旧 localStorage 覆盖新数据）

        const seedKeys = typeof SLOWRISE_SEED !== 'undefined' ? Object.keys(SLOWRISE_SEED) : [];

        for (const k of seedKeys) {

          if (!merged[k]) merged[k] = SLOWRISE_SEED[k];

        }

        saveTrendHistory(merged);

        console.log('[SlowRise] Merged history:', Object.keys(merged).length, 'days');

      } catch (e) {

        console.warn('[SlowRise] Failed to load server history:', e);

      }

    }


    function saveTrendHistory(history) {

      try {

        localStorage.setItem(SLOWRISE_KEY, JSON.stringify(history));

      } catch (e) { console.warn('localStorage save failed:', e); }

    }


    function computeSlowRise(sectors, tradingDate) {

      if (!tradingDate) return [];


      const history = loadTrendHistory();

      let todayRanks = {};


      // If we have live sector data, record today's rankings

      if (sectors && sectors.length > 0) {

        sectors.forEach((s, i) => { todayRanks[s.name] = i + 1; });

        history[tradingDate] = todayRanks;

      }


      // Clean up history older than 30 days

      const cutoff = new Date(tradingDate);

      cutoff.setDate(cutoff.getDate() - 30);

      const cutoffStr = localDateStr(cutoff);

      for (const key of Object.keys(history)) {

        if (key < cutoffStr) delete history[key];

      }


      saveTrendHistory(history);


      // Find sectors with consecutive rank improvement

      const sortedDates = Object.keys(history).sort();

      const slowRise = [];


      // Collect all sector names from the most recent date in history

      const latestDate = sortedDates[sortedDates.length - 1];

      const latestRanks = history[latestDate] || {};

      const allNames = Object.keys(todayRanks).length > 0 ? Object.keys(todayRanks) : Object.keys(latestRanks);


      for (const name of allNames) {

        let streak = 0;

        let prevRank = null;

        let consecutive = true;


        // Walk forward through dates (oldest → newest)

        for (let i = 0; i < sortedDates.length; i++) {

          const d = sortedDates[i];

          const ranks = history[d];

          if (ranks && ranks[name] !== undefined) {

            if (prevRank === null) {

              prevRank = ranks[name];

            } else if (ranks[name] < prevRank) {

              // Rank number decreased = position improved

              streak++;

              prevRank = ranks[name];

            } else {

              consecutive = false;

              break;

            }

          }

        }


        if (consecutive && streak >= 2) {

          const latestRank = latestRanks[name];

          slowRise.push({ name, streak, today_rank: latestRank, days: streak });

        }

      }


      slowRise.sort((a, b) => b.streak - a.streak);

      return slowRise;

    }


    // ============================================================

    //  RPS — 相对强弱排名 (Relative Price Strength)

    //  RPS = (1 - 排名/N) × 100，基于板块当日涨跌幅排名

    //  同时追踪 RPS20/RPS60/RPS120 历史（localStorage）

    // ============================================================

    const RPS_HISTORY_KEY = 'vibe_rps_history';


    function loadRpsHistory() {

      try {

        const data = localStorage.getItem(RPS_HISTORY_KEY);

        return data ? JSON.parse(data) : {};

      } catch { return {}; }

    }


    function saveRpsHistory(history) {

      try {

        localStorage.setItem(RPS_HISTORY_KEY, JSON.stringify(history));

      } catch (e) { console.warn('RPS history save failed:', e); }

    }


    function computeRPS(sectors, tradingDate) {

      if (!sectors || sectors.length === 0) return [];


      const N = sectors.length;

      // Sort by change descending for today's RPS

      const sorted = [...sectors].sort((a, b) => b.change - a.change);

      const rankMap = {};

      sorted.forEach((s, i) => { rankMap[s.name] = i + 1; });


      const todayRPS = {};

      for (const s of sectors) {

        todayRPS[s.name] = Math.round((1 - rankMap[s.name] / N) * 100);

      }


      // Load and update history

      const history = loadRpsHistory();

      history[tradingDate] = todayRPS;


      // Clean up history older than 180 days

      const cutoff = new Date(tradingDate);

      cutoff.setDate(cutoff.getDate() - 180);

      const cutoffStr = localDateStr(cutoff);

      for (const key of Object.keys(history)) {

        if (key < cutoffStr) delete history[key];

      }

      saveRpsHistory(history);


      // Calculate RPS20/RPS60/RPS120 from history

      const sortedDates = Object.keys(history).sort();

      const rpsData = [];


      for (const s of sectors) {

        const rps60Values = [];

        const rps20Values = [];

        const rps120Values = [];


        // Last 120 trading days

        const recent120 = sortedDates.slice(-120);

        const recent60 = sortedDates.slice(-60);

        const recent20 = sortedDates.slice(-20);


        for (const d of recent60) {

          if (history[d] && history[d][s.name] !== undefined) {

            rps60Values.push(history[d][s.name]);

          }

        }

        for (const d of recent20) {

          if (history[d] && history[d][s.name] !== undefined) {

            rps20Values.push(history[d][s.name]);

          }

        }

        for (const d of recent120) {

          if (history[d] && history[d][s.name] !== undefined) {

            rps120Values.push(history[d][s.name]);

          }

        }


        const avg = arr => arr.length > 0 ? Math.round(arr.reduce((a, b) => a + b, 0) / arr.length) : null;


        const rps20 = rps20Values.length >= 5 ? avg(rps20Values) : todayRPS[s.name];

        const rps60 = rps60Values.length >= 10 ? avg(rps60Values) : todayRPS[s.name];

        const rps120 = rps120Values.length >= 20 ? avg(rps120Values) : todayRPS[s.name];


        // Trend: compare recent 3 days vs prior 3 days

        const recent3 = sortedDates.slice(-3);

        const prev3 = sortedDates.slice(-6, -3);

        let trend = '→';

        if (recent3.length >= 2 && prev3.length >= 2) {

          const recentAvg = avg(recent3.map(d => history[d]?.[s.name]).filter(v => v != null));

          const prevAvg = avg(prev3.map(d => history[d]?.[s.name]).filter(v => v != null));

          if (recentAvg != null && prevAvg != null) {

            if (recentAvg - prevAvg > 3) trend = '↑';

            else if (recentAvg - prevAvg < -3) trend = '↓';

          }

        }


        rpsData.push({

          name: s.name,

          change: s.change,

          rps20, rps60, rps120, trend,

          strength: rpsLabel(rps20)

        });

      }


      // Sort by RPS descending

      rpsData.sort((a, b) => b.rps20 - a.rps20);

      rpsData.forEach((d, i) => { d.rank = i + 1; });

      return rpsData;

    }


    function rpsLabel(v) {

      if (v >= 90) return '极强';

      if (v >= 80) return '强势';

      if (v >= 70) return '偏强';

      if (v >= 50) return '中等';

      if (v >= 40) return '偏弱';

      return '弱势';

    }


    function rpsColor(v) {

      if (v >= 90) return '#ff2d2d';

      if (v >= 80) return '#ff6b35';

      if (v >= 70) return '#ffb333';

      if (v >= 50) return '#39ff14';

      if (v >= 40) return '#22bbaa';

      return '#4488cc';

    }


    function rpsBgColor(v) {

      if (v >= 90) return 'rgba(255,45,45,0.15)';

      if (v >= 80) return 'rgba(255,107,53,0.12)';

      if (v >= 70) return 'rgba(255,179,51,0.1)';

      if (v >= 50) return 'rgba(57,255,20,0.08)';

      if (v >= 40) return 'rgba(34,187,170,0.06)';

      return 'rgba(68,136,204,0.05)';

    }


    function rpsStrengthBg(v) {

      if (v >= 90) return 'rgba(255,45,45,0.3)';

      if (v >= 80) return 'rgba(255,107,53,0.25)';

      if (v >= 70) return 'rgba(255,179,51,0.2)';

      if (v >= 50) return 'rgba(57,255,20,0.15)';

      if (v >= 40) return 'rgba(34,187,170,0.12)';

      return 'rgba(68,136,204,0.1)';

    }


    function updateRPS(rpsData) {

      const container = document.getElementById('rps-content');

      // Update RPS date display - use data date if available
      const rpsTimeEl = document.getElementById('rps-update-time');
      if (rpsTimeEl && rpsData && rpsData.length > 0) {
        const dataDate = window._rpsDataDate || localDateStr();
        const isToday = dataDate === localDateStr();
        let dateHint = dataDate;
        if (!isToday) dateHint += ' (\u975e\u4eca\u65e5\uff0c\u8282\u5047\u65e5\u6cbf\u7528\u6700\u8fd1\u4ea4\u6613\u65e5)';
        rpsTimeEl.textContent = '\u26f3 \u6bcf\u65e510:00\u66f4\u65b0 | ' + dateHint + ' | v0.0.42';
      }

      if (!rpsData || rpsData.length === 0) {

        container.innerHTML = '<div class="error-msg">暂无数据</div>';

        return;

      }


      const trendIcon = { 
  '↑': '<svg width="14" height="14" viewBox="0 0 14 14"><polygon points="7,2 12,12 2,12" fill="var(--neon-red)"/></svg>',
  '↓': '<svg width="14" height="14" viewBox="0 0 14 14"><polygon points="7,12 2,2 12,2" fill="var(--neon-green)"/></svg>',
  '→': '<svg width="14" height="14" viewBox="0 0 14 14"><polygon points="2,7 12,3 12,11" fill="#888888"/></svg>', 
  '↑': '<svg width="14" height="14" viewBox="0 0 14 14"><polygon points="7,2 12,12 2,12" fill="var(--neon-red)"/></svg>',
  '↓': '<svg width="14" height="14" viewBox="0 0 14 14"><polygon points="7,12 2,2 12,2" fill="var(--neon-green)"/></svg>',
  '→': '<svg width="14" height="14" viewBox="0 0 14 14"><polygon points="2,7 12,3 12,11" fill="#888888"/></svg>'
};

      const strongCount = rpsData.filter(d => d.rps20 >= 80).length;

      const weakCount = rpsData.filter(d => d.rps20 < 40).length;


      let html = `<div style="margin-bottom:12px;color:rgba(255,255,255,0.6);font-size:0.8rem;">

        <span style="color:var(--neon-red);font-weight:700;">强势 ${strongCount}</span> 个 &nbsp;|&nbsp; 

        <span style="color:var(--neon-green);font-weight:700;">弱势 ${weakCount}</span> 个 &nbsp;|&nbsp; 

        RPS = (1 - 排名/N) × 100

      </div>`;


      html += `<table class="rps-table">

        <thead><tr>

          <th>排名</th><th>行业板块</th><th>涨跌</th>

          <th>RPS</th>

          <th>趋势</th><th>强度</th>

        </tr></thead><tbody>`;


      for (const d of rpsData) {

        const color = rpsColor(d.rps20);

        const barW = d.rps20 + '%';

        html += `<tr style="background:${rpsBgColor(d.rps20)};">

          <td style="color:${color};font-weight:700;">${d.rank}</td>

          <td><a href="https://www.baidu.com/s?wd=${encodeURIComponent(d.name + '板块')}" target="_blank" style="color:${color};text-decoration:none;" title="查看${d.name}板块详情">${d.name}</a></td>

          <td style="color:${d.change >= 0 ? 'var(--neon-red)' : 'var(--neon-green)'};">${d.change >= 0 ? '+' : ''}${d.change.toFixed(2)}%</td>

          <td>

            <div class="rps-cell">

              <span class="rps-num" style="color:${rpsColor(d.rps20)};">${d.rps20}</span>

              <div style="flex:1;height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;">

                <div class="rps-bar" style="width:${d.rps20}%;background:${rpsColor(d.rps20)};"></div>

              </div>

            </div>

          </td>

          

          

          <td class="rps-trend ${d.trend === '↑' ? 'up' : d.trend === '↓' ? 'down' : ''}">${trendIcon[d.trend] || d.trend}</td>

          <td><span class="rps-strength" style="color:${color};background:${rpsStrengthBg(d.rps20)};">${d.strength}</span></td>

        </tr>`;

      }


      html += '</tbody></table>';

      container.innerHTML = html;

    }


    // ============================================================

    //  UI UPDATE FUNCTIONS

    // ============================================================

    let currentTab = 'industry';

    let cachedData = null;


    function setStatus(connected) {

      // No visible status indicator — just log

      console.log('[VIBE] Status:', connected ? 'connected' : 'disconnected');

    }


    function updateSentiment(data) {

      if (!data) return;

      const circumference = 2 * Math.PI * 85;

      const offset = circumference - (data.overall / 100) * circumference;

      document.getElementById('gauge-arc').style.strokeDashoffset = offset;

      document.getElementById('sentiment-value').textContent = data.overall;

      document.getElementById('bullish-bar').style.width = data.bullish + '%';

      document.getElementById('neutral-bar').style.width = data.neutral + '%';

      document.getElementById('bearish-bar').style.width = data.bearish + '%';

      document.getElementById('bullish-pct').textContent = data.bullish.toFixed(0) + '%';

      document.getElementById('neutral-pct').textContent = data.neutral.toFixed(0) + '%';

      document.getElementById('bearish-pct').textContent = data.bearish.toFixed(0) + '%';

    }


    let slowRiseVersion = 0;

        function updateSlowRise(data) {
      const grid = document.getElementById('sector-grid');
      if (!data || data.length === 0) {
        grid.innerHTML = '<div class="slowrise-empty">近5个交易日无板块递进≥3天</div>';
        return;
      }
      let html = data.slice(0, 5).map(s => {
        const colors = { 1: '#ff8c00', 0: '#666666', '-1': '#87ceeb' };
        const trendBoxes = (s.trend || []).map((t, i) => {
          const bg = colors[t] || colors[0];
          return '<div style="width:22px;height:22px;background:' + bg + ';border-radius:3px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:9px;font-weight:bold;box-shadow:0 0 4px ' + bg + ';margin-right:4px;">' + (i+1) + '</div>';
        }).join('');

        let color, glow;
        if (s.days >= 5) {
          color = '#00e5ff'; glow = 'text-shadow:0 0 8px #00e5ff,0 0 16px #00e5ff;';
        } else if (s.days >= 4) {
          color = '#39ff14'; glow = 'text-shadow:0 0 6px #39ff14;';
        } else {
          color = '#ff8c00'; glow = 'text-shadow:0 0 6px #ff8c00;';
        }

        return '<div class="sector-item" style="background:rgba(0,0,0,0.3);padding:10px;margin-bottom:6px;border-radius:5px;">' +
            '<div style="display:flex;align-items:center;flex-wrap:wrap;gap:8px;">' +
              '<span class="sector-name" style="color:' + color + ';' + glow + 'font-weight:600;">' + s.name + '</span>' +
              trendBoxes +
              '<span style="color:' + color + ';' + glow + 'font-family:JetBrains Mono,monospace;font-size:0.85rem;">🔥 ' + s.days + '天↑</span>' +
            '</div>' +
          '</div>';
      }).join('');

      // Anti-flicker
      grid.innerHTML = html;
    }


    function updateSectors(sectors) {
      const grid = document.getElementById('sector-grid');
      if (!sectors || sectors.length === 0) {
        grid.innerHTML = '<div class="error-msg">no data</div>';
        return;
      }
      // redirect removed - tab handler calls correct function directly
      let html = '<div class="sector-tbl-wrap"><table class="sector-tbl"><thead><tr><th style="width:10%">#</th><th style="width:30%">名称</th><th style="width:20%">涨跌幅</th><th style="width:40%">强度</th></tr></thead><tbody>';
      sectors.slice(0, 15).forEach((s, idx) => {
        const rank = idx + 1;
        const isUp = s.change >= 0;
        const chgColor = isUp ? '#ff0028' : '#39ff14';
        const chgText = (isUp ? '+' : '') + s.change.toFixed(2) + '%';
        // STR条宽度 = |change| * 20，范围 8~100%
        const barW = Math.max(8, Math.min(100, Math.round(Math.abs(s.change) * 20)));
        const strClass = isUp ? 'str-bar-fishbone up' : 'str-bar-fishbone down';
        html += '<tr data-' + (isUp ? 'up' : 'down') + '>' +
          '<td class="rank-cell">' + rank + '</td>' +
          '<td class="sector-name-cell"><a href="' + s.link + '" target="_blank" class="sector-link">' + s.name + '</a></td>' +
          '<td class="change-cell" style="color:' + chgColor + '">' + chgText + '</td>' +
          '<td class="str-cell"><div class="' + strClass + '"><div class="rps-fill" style="width:' + barW + '%;"></div></div><span class="str-pct">' + chgText + '</span></td>' +
          '</tr>';
      });
      html += '</tbody></table></div>';
      // Anti-flicker: only update if content actually changed
      grid.innerHTML = html;
    }


                function updateConcepts(concepts) {
      const grid = document.getElementById('sector-grid');
      if (!concepts || concepts.length === 0) {
        grid.innerHTML = '<div class="error-msg">no data</div>';
        return;
      }
      let html = '<div class="concept-tbl-wrap"><table class="concept-tbl"><thead><tr><th style="width:10%">#</th><th style="width:30%">名称</th><th style="width:20%">涨跌幅</th><th style="width:40%">强度</th></tr></thead><tbody>';
      concepts.slice(0, 15).forEach((c, idx) => {
        const rank = idx + 1;
        const isUp = c.change >= 0;
        const chgColor = isUp ? '#ff0092' : '#7986cb';
        const chgText = (isUp ? '+' : '') + c.change.toFixed(2) + '%';
        // STR条宽度 = |change| * 20，范围 8~100%
        const barW = Math.max(8, Math.min(100, Math.round(Math.abs(c.change) * 20)));
        const strClass = isUp ? 'str-bar-single up' : 'str-bar-single down';
        html += '<tr data-' + (isUp ? 'up' : 'down') + '>' +
          '<td class="rank-cell">' + rank + '</td>' +
          '<td class="sector-name-cell"><a href="' + c.link + '" target="_blank" class="sector-link">' + c.name + '</a></td>' +
          '<td class="change-cell" style="color:' + chgColor + '">' + chgText + '</td>' +
          '<td class="str-cell"><div class="' + strClass + '"><div class="rps-fill" style="width:' + barW + '%;"></div></div><span class="str-pct">' + chgText + '</span></td>' +
          '</tr>';
      });
      html += '</tbody></table></div>';
      // Anti-flicker: only update if content actually changed
      grid.innerHTML = html;
    }


    function updateAlerts(alerts) {

      const list = document.getElementById('alert-list');

      if (!alerts || alerts.length === 0) {

        list.innerHTML = '<div class="loading">暂无异动</div>';

        return;

      }

      const parseChange = (title) => {

        const match = title.match(/([+-]?[\d.]+)%/);

        if (match) {

          const pct = parseFloat(match[0]);

          if (pct > 0) return `<span style="color:var(--neon-red);text-shadow:0 0 4px var(--neon-red);">+${pct.toFixed(2)}%</span>`;

          if (pct < 0) return `<span style="color:var(--neon-green);">${pct.toFixed(2)}%</span>`;

          return `<span style="color:var(--neon-cyan);">${pct.toFixed(2)}%</span>`;

        }

        return null;

      };

      list.innerHTML = alerts.map(a => {

        const changeSpan = parseChange(a.title);

        let namePart = a.title.replace(/\[.*?\]\s*/, '').replace(/[+-]?[\d.]+%/, '').trim();

        return `<div class="alert-item alert-${a.type}">

          <div style="display:flex;justify-content:space-between;width:100%;">

            <span style="flex:1;">${namePart}</span>

            <span style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;min-width:60px;text-align:right;">${changeSpan || ''}</span>

          </div>

          <div class="alert-time" style="margin-top:4px;">${a.time}</div>

        </div>`;

      }).join('');

    }


    function updateSourceBars(sectors) {

      const container = document.getElementById('source-bars');

      if (!sectors || sectors.length === 0) {

        container.innerHTML = '<div class="error-msg">暂无数据</div>';

        return;

      }

      const upCount = sectors.filter(s => s.change > 0).length;

      const downCount = sectors.filter(s => s.change < 0).length;

      const avgChange = sectors.reduce((a, b) => a + b.change, 0) / sectors.length;

      const maxUp = Math.max(...sectors.map(s => s.change));

      const maxDown = Math.min(...sectors.map(s => s.change));


      const metrics = [

        { label: '上涨板块', value: upCount, max: sectors.length, color: 'var(--neon-red)' },

        { label: '下跌板块', value: downCount, max: sectors.length, color: 'var(--neon-green)' },

        { label: '平均涨跌', value: avgChange * 10 + 50, max: 100, color: avgChange >= 0 ? 'var(--neon-red)' : 'var(--neon-green)', suffix: `${avgChange.toFixed(2)}%` },

        { label: '最大涨幅', value: Math.max(0, maxUp) * 5, max: 100, color: 'var(--neon-red)', suffix: `${maxUp.toFixed(2)}%` },

        { label: '最大跌幅', value: Math.abs(maxDown) * 5, max: 100, color: 'var(--neon-green)', suffix: `${maxDown.toFixed(2)}%` }

      ];


      container.innerHTML = metrics.map(m => `

        <div class="source-bar">

          <span class="source-label">${m.label}</span>

          <div class="source-progress">

            <div class="source-fill" style="width:${Math.min(100, Math.max(0, m.value))}%;background:${m.color}"></div>

          </div>

          <span class="source-value" style="color:${m.color}">${m.suffix || m.value}</span>

        </div>

      `).join('');

    }


    // ============================================================

    //  MAIN — 获取数据并刷新界面

    // ============================================================

    // ============================================================


    // MAIN — 获取数据并刷新界面（独立降级模式）

    // ============================================================

    async function refreshAll() {


      // 各数据源独立加载，失败不影响其他数据源

      let sectorRaw = null;

      let conceptRaw = null;

      let stocks = null;


      // 0. 加载美股选股
      try {
        loadUSPicks();
      } catch (e) {
        console.warn('[VIBE] loadUSPicks failed:', e);
      }

      // 1. 加载服务端慢热历史数据（首次访问 localStorage 为空时需要）

      try {

        await loadTrendHistoryFromServer();

      } catch (e) {

        console.warn('[VIBE] loadTrendHistoryFromServer failed:', e);

      }


      // 1. 腾讯 API 数据（板块 + 概念）

      try {

        const sectorCodes = [...new Set(Object.values(SECTOR_REPRESENTATIVES).flat())];

        const conceptCodes = [...new Set(Object.values(CONCEPT_CODES).flat())];

        const [s, c] = await Promise.all([

          fetchTencentData(sectorCodes),

          fetchTencentData(conceptCodes)

        ]);

        sectorRaw = s;

        conceptRaw = c;

      } catch (e) {

        console.error('[VIBE] fetchTencentData failed:', e);

      }


      // 2. 每日选股数据

      try {

        stocks = await processStocks();

      } catch (e) {

        console.error('[VIBE] processStocks failed:', e);

      }


      // 3. 处理数据（失败不影响渲染）

      let sectors = [], concepts = [], sentiment = null, alerts = [], slowRise = [], rpsData = null;

      let tradingDate = localDateStr();

      try {

        const sectorStockData = sectorRaw ? parseStockData(sectorRaw) : {};

        const conceptStockData = conceptRaw ? parseStockData(conceptRaw) : {};

        sectors = processSectors(sectorStockData);

        concepts = processConcepts(conceptStockData);

        sentiment = calculateSentiment(sectors);

        alerts = generateAlerts(sectors, concepts);

        slowRise = computeSlowRise(sectors, tradingDate);

        rpsData = computeRPS(sectors, tradingDate);
        // === Overlay sector_rankings from daily_picks.json if available ===
        try {
          let srData = null;
          // Try window._dailyPicksData first (set by loadDailyPicks)
          // Priority 1: sector-rankings-embed (works on file:// protocol)
          try {
            const srEmbed = document.getElementById('sector-rankings-embed');
            if (srEmbed) {
              const srParsed = JSON.parse(srEmbed.textContent);
              if (srParsed && Object.keys(srParsed).length > 0 && !srParsed.__placeholder__) {
                srData = srParsed;
                console.log('[VIBE-RPS] Using sector-rankings-embed, dates:', Object.keys(srData).length);
              }
            }
          } catch(esr) { console.warn('[VIBE-RPS] sector-rankings-embed parse failed:', esr.message); }
          // Priority 2: window._dailyPicksData (set by loadDailyPicks)
          if (!srData && window._dailyPicksData && window._dailyPicksData.sector_rankings) {
            srData = window._dailyPicksData.sector_rankings;
          }
          // Priority 3: fetch daily_picks.json directly (fails on file:// due to CORS)
          if (!srData) {
            try {
              const resp = await fetch('daily_picks.json', { cache: 'no-store' });
              if (resp.ok) {
                const dp = await resp.json();
                if (dp.sector_rankings) srData = dp.sector_rankings;
              }
            } catch(ef) { console.warn('[VIBE-RPS] fallback fetch failed:', ef.message); }
          }
          if (srData) {
            const srKeys = Object.keys(srData).sort().reverse();
            const latestSRKey = srKeys[0];
            if (latestSRKey) {
              const srEntries = srData[latestSRKey];
              if (srEntries && srEntries.length > 0) {
                rpsData = srEntries.map(s => ({
                  name: s.name,
                  change: s.change_pct || 0,
                  rank: s.rank,
                  rps20: s.rps || 0,
                  trend: s.trend || '-',
                  strength: s.strength || ''
                }));
                console.log('[VIBE-RPS] Using sector_rankings from', latestSRKey, '- count:', srEntries.length);
                // Store RPS data date for updateRPS()
                window._rpsDataDate = latestSRKey;
                // Update RPS date display with refresh time
                const rpsTimeEl = document.getElementById('rps-update-time');
                if (rpsTimeEl) {
                  const refreshTime = new Date().toLocaleTimeString('zh-CN', {hour12: false});
                  rpsTimeEl.textContent = '⛳ 每日10:00更新 | ' + latestSRKey + ' ' + refreshTime + ' | v0.0.42';
                }
              }
            }
          }
        } catch(e3) { console.warn('[VIBE-RPS] sector_rankings overlay failed:', e3.message); }

        // Fallback: ensure date is always shown
        const rpsTimeEl2 = document.getElementById('rps-update-time');
        if (rpsTimeEl2 && !rpsTimeEl2.textContent.includes('|')) {
          rpsTimeEl2.textContent = '⛳ 每日10:00更新 | ' + localDateStr() + ' | v0.0.42';
        }
        console.log('[VIBE-RPS] final rpsData count:', rpsData ? rpsData.length : 'null');


        cachedData = { sectors, stocks, concepts, sentiment, alerts, slowRise, rpsData, tradingDate };

        setStatus(true);

      } catch (e) {

        console.error('[VIBE] processData failed:', e);

      }


      // 4. 各 UI 面板独立更新（每个独立 try-catch，一个失败不影响其他）

      try { if (sentiment !== null) updateSentiment(sentiment); } catch(e) { console.error('[VIBE] updateSentiment:', e); }

      try {
        if (currentTab === 'slowrise') updateSlowRise(slowRise);
        else if (currentTab === 'concept') updateConcepts(concepts);
        else updateSectors(sectors);
      } catch(e) { console.error('[VIBE] updateSectors:', e); }

      try { updateStocks(stocks); } catch(e) { console.error('[VIBE] updateStocks:', e); }

      // concepts already rendered in tab logic above, skip duplicate
      // try { updateConcepts(cachedData?.concepts || concepts); } catch(e) { console.error('[VIBE] updateConcepts:', e); }

      try { updateAlerts(alerts); } catch(e) { console.error('[VIBE] updateAlerts:', e); }

      try { updateSourceBars(cachedData?.sectors || sectors); } catch(e) { console.error('[VIBE] updateSourceBars:', e); }

      try { updateRPS(cachedData?.rpsData || rpsData); } catch(e) { console.error('[VIBE] updateRPS:', e); }


      // 更新时间
      const timeEl = document.getElementById('update-time');
      if (timeEl) timeEl.textContent = new Date().toLocaleTimeString('zh-CN', {hour12: false});



    }


    // Tab switching

    document.querySelectorAll('.tab-btn').forEach(btn => {

      btn.addEventListener('click', () => {

        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));

        btn.classList.add('active');

        currentTab = btn.dataset.type;

        if (cachedData) {
          try {


          if (currentTab === 'slowrise') {

            updateSlowRise(cachedData?.slowRise || []);

          } else if (currentTab === 'concept') {

            updateConcepts(cachedData?.concepts || []);

          } else {

            updateSectors(cachedData?.sectors || []);

          }

                  } catch(e) {
            console.error('[VIBE] tab click:', e);
          }
        } else {
          refreshAll();
        }
      });

    });


    // Initialize

    refreshAll();


    // Auto refresh every 30 seconds

    setInterval(refreshAll, 30000);

  </script>

