.us-stock-panel { width: 100% !important; }
.us-table { width: 100% !important; table-layout: fixed !important; font-size: 11px !important; word-break: break-all !important; }
.us-table thead th { font-size: 11px !important; text-align: left !important; white-space: nowrap !important; overflow: hidden !important; text-overflow: ellipsis !important; padding: 4px 2px !important; color: cyan !important; }
.us-table tbody td { white-space: nowrap !important; overflow: hidden !important; text-overflow: ellipsis !important; padding: 3px 2px !important; }
.us-table th:nth-child(1), .us-table td:nth-child(1) { width: 8% !important; }
.us-table th:nth-child(2), .us-table td:nth-child(2) { width: 13% !important; }
.us-table th:nth-child(3), .us-table td:nth-child(3) { width: 9% !important; }
.us-table th:nth-child(4), .us-table td:nth-child(4) { width: 9% !important; }
.us-table th:nth-child(5), .us-table td:nth-child(5) { width: 7% !important; }
.us-table th:nth-child(6), .us-table td:nth-child(6) { width: 7% !important; }
.us-table th:nth-child(7), .us-table td:nth-child(7) { width: 7% !important; }
.us-table th:nth-child(8), .us-table td:nth-child(8) { width: 7% !important; }
.us-table th:nth-child(9), .us-table td:nth-child(9) { width: 7% !important; }
.us-table th:nth-child(10), .us-table td:nth-child(10) { width: 18% !important; }
.us-table th:nth-child(11), .us-table td:nth-child(11) { width: 8% !important; }
.us-table .num { text-align: left !important; font-size: 11px !important; }
.us-update-time { font-size: 14px !important; }
.us-table-wrap { overflow-x: auto !important; }
.us-table tbody tr:nth-child(even) { background: rgba(255,255,255,0.12) !important; }
.us-table-wrap { overflow-x: auto !important; -webkit-overflow-scrolling: touch !important; }
@media (max-width: 768px) {
  .us-table { min-width: 700px !important; width: 700px !important; table-layout: fixed !important; }
  .us-table-wrap { overflow-x: auto !important; -webkit-overflow-scrolling: touch !important; width: 100% !important; }
}
.us-picks-header { font-size: 13px !important; }
@media (max-width: 768px) { .us-picks-header { font-size: 8px !important; } }
.us-code a:hover { color: #00ff88 !important; text-decoration: underline !important; text-shadow: 0 0 8px #00ff88; }
</style>

<style>
.sector-tbl, .concept-tbl { table-layout: fixed !important; width: 100% !important; }
</style>
<style>
.sector-tbl th, .sector-tbl td, .concept-tbl th, .concept-tbl td { text-align: left !important; }
</style>
<style>
.sector-tbl .str-cell, .concept-tbl .str-cell { text-align: center !important; }
</style>
<style>
.sector-tbl .str-cell, .concept-tbl .str-cell { justify-content: center !important; }
.sector-tbl th:last-child, .concept-tbl th:last-child { text-align: center !important; }
</style>

<style>
/* 行业表STR双层辉光 - 涨红跌绿 */
.str-bar-fishbone.up .rps-fill { background: linear-gradient(90deg, transparent 0%, rgba(255,45,45,0.15) 15%, rgba(255,45,45,0.6) 35%, rgba(255,45,45,1) 50%, rgba(255,45,45,0.6) 65%, rgba(255,45,45,0.15) 85%, transparent 100%) !important; box-shadow: 0 0 8px rgba(255,45,45,0.6), 0 0 20px rgba(255,45,45,0.25) !important; }
.str-bar-fishbone.down .rps-fill { background: linear-gradient(90deg, transparent 0%, rgba(57,255,20,0.15) 15%, rgba(57,255,20,0.6) 35%, rgba(57,255,20,1) 50%, rgba(57,255,20,0.6) 65%, rgba(57,255,20,0.15) 85%, transparent 100%) !important; box-shadow: 0 0 8px rgba(57,255,20,0.6), 0 0 20px rgba(57,255,20,0.25) !important; }
.str-bar-single.up .rps-fill { background: linear-gradient(90deg, rgba(255,0,146,1) 0%, rgba(255,0,146,0.7) 30%, rgba(255,0,146,0.3) 70%, transparent 100%) !important; box-shadow: 0 0 8px rgba(255,0,146,0.6), 0 0 20px rgba(255,0,146,0.25) !important; }
.str-bar-single.down .rps-fill { background: linear-gradient(90deg, rgba(92,107,192,1) 0%, rgba(92,107,192,0.7) 30%, rgba(92,107,192,0.3) 70%, transparent 100%) !important; box-shadow: 0 0 8px rgba(92,107,192,0.6), 0 0 20px rgba(92,107,192,0.25) !important; }
.sector-tbl tbody td:nth-child(1), .sector-tbl tbody td:nth-child(2) { font-weight: 700 !important; }
.sector-tbl tbody tr.up td:nth-child(1), .sector-tbl tbody tr.up td:nth-child(2) { color: #ff2d2d !important; }
.sector-tbl tbody tr.down td:nth-child(1), .sector-tbl tbody tr.down td:nth-child(2) { color: #39ff14 !important; }
.concept-tbl tbody td:nth-child(1), .concept-tbl tbody td:nth-child(2) { font-weight: 700 !important; }
.concept-tbl tbody tr[data-up] td:nth-child(1), .concept-tbl tbody tr[data-up] td:nth-child(2) { color: #ff0092 !important; }
.concept-tbl tbody tr[data-down] td:nth-child(1), .concept-tbl tbody tr[data-down] td:nth-child(2) { color: #5c6bc0 !important; }
.concept-tbl tbody tr[data-up] td { color: #ff0092 !important; }
.concept-tbl tbody tr[data-down] td { color: #5c6bc0 !important; }
</style>

<style>
/* RPS涨跌列(第3列)加粗 */
.rps-table th:nth-child(3) { font-weight: 700 !important; }
.rps-table td:nth-child(3) { font-weight: 700 !important; }
</style>
</body>
</html>
