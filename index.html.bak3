modal-body,.css-13erb5t.ant-modal-pure-panel .ant-modal-confirm-body-wrapper{display:flex;flex-direction:column;flex:auto;}.css-13erb5t.ant-modal-pure-panel .ant-modal-confirm-body{margin-bottom:auto;}.css-13erb5t.ant-modal-root .ant-modal-wrap-rtl{direction:rtl;}.css-13erb5t.ant-modal-root .ant-modal-wrap-rtl .ant-modal-confirm-body{direction:rtl;}.css-13erb5t.ant-modal-root .ant-modal.ant-zoom-enter,.css-13erb5t.ant-modal-root .ant-modal.ant-zoom-appear{transform:none;opacity:0;animation-duration:var(--ant-motion-duration-slow);user-select:none;}.css-13erb5t.ant-modal-root .ant-modal.ant-zoom-leave .ant-modal-content{pointer-events:none;}.css-13erb5t.ant-modal-root .ant-modal-mask{position:fixed;inset:0;z-index:var(--ant-z-index-popup-base);height:100%;background-color:var(--ant-color-bg-mask);pointer-events:none;}.css-13erb5t.ant-modal-root .ant-modal-mask .ant-modal-hidden{display:none;}.css-13erb5t.ant-modal-root .ant-modal-wrap{position:fixed;inset:0;z-index:var(--ant-z-index-popup-base);overflow:auto;outline:0;-webkit-overflow-scrolling:touch;}.css-13erb5t.ant-modal-root .ant-fade-enter,.css-13erb5t.ant-modal-root .ant-fade-appear{animation-duration:var(--ant-motion-duration-mid);animation-fill-mode:both;animation-play-state:paused;}.css-13erb5t.ant-modal-root .ant-fade-leave{animation-duration:var(--ant-motion-duration-mid);animation-fill-mode:both;animation-play-state:paused;}.css-13erb5t.ant-modal-root .ant-fade-enter.ant-fade-enter-active,.css-13erb5t.ant-modal-root .ant-fade-appear.ant-fade-appear-active{animation-name:css-13erb5t-antFadeIn;animation-play-state:running;}.css-13erb5t.ant-modal-root .ant-fade-leave.ant-fade-leave-active{animation-name:css-13erb5t-antFadeOut;animation-play-state:running;pointer-events:none;}.css-13erb5t.ant-modal-root .ant-fade-enter,.css-13erb5t.ant-modal-root .ant-fade-appear{opacity:0;animation-timing-function:linear;}.css-13erb5t.ant-modal-root .ant-fade-leave{animation-timing-function:linear;}.css-13erb5t.ant-zoom-ente