<section class="card us-stock-panel" style="grid-column: 1 / -1; width: 100%; max-width: 100%;">
        <h2 class="card-title">🇺🇸 每日美股选股推荐</h2>
        <div class="us-stock-container" id="us-stock-list" style="display:flex;flex-direction:column;gap:8px;max-height:none;overflow:visible;width:100%;">
          <div class="us-update-time">⛳ 每日10:00更新 | 数据加载中...</div>
        </div>
      </section>

      <!-- MODULE: alert-panel -->
<!-- MODULE: alerts -->
<section class="card alert-panel">

        <h2 class="card-title">市场异动</h2>

        <div class="alert-list" id="alert-list"><div class="alert-item alert-hot">

          <div style="display:flex;justify-content:space-between;width:100%;">

            <span style="flex:1;">钢铁</span>

            <span style="font-family:&#39;JetBrains Mono&#39;,monospace;font-size:0.85rem;min-width:60px;text-align:right;"><span style="color:var(--neon-red);text-shadow:0 0 4px var(--neon-red);">+2.96%</span></span>

          </div>

          <div class="alert-time" style="margin-top:4px;">13:47:51</div>

        </div><div class="alert-item alert-warning">

          <div style="display:flex;justify-content:space-between;width:100%;">

            <span style="flex:1;">半导体</span>

            <span style="font-family:&#39;JetBrains Mono&#39;,monospace;font-size:0.85rem;min-width:60px;text-align:right;"><span style="color:var(--neon-green);">-2.72%</span></span>

          </div>

          <div class="alert-time" style="margin-top:4px;">13:47:51</div>

        </div><div class="alert-item alert-hot">

          <div style="display:flex;justify-content:space-between;width:100%;">

            <span style="flex:1;">传媒</span>

            <span style="font-family:&#39;JetBrains Mono&#39;,monospace;font-size:0.85rem;min-width:60px;text-align:right;"><span style="color:var(--neon-red);text-shadow:0 0 4px var(--neon-red);">+2.37%</span></span>

          </div>

          <div class="alert-time" style="margin-top:4px;">13:47:51</div>

        </div>

    


</div>

      
    <div class="fear-greed-wrap" style="margin-top:15px; text-align:center;">
      <div style="text-align:center;">
        <div style="position:relative; display:inline-block; max-width:380px; width:100%;">
          <img src="gauge_bg.png" style="width:100%; height:auto; display:block;" alt="fear-greed gauge"/>
          <svg viewBox="0 0 380 191" style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none;">
            <g id="fear-greed-needle" transform="rotate(-36 190 165)">
              <polygon points="185,165 195,165 190,65" fill="#ff3355" stroke="#ffffff" stroke-width="2"/>
              <circle cx="190" cy="165" r="10" fill="#ff3355" stroke="#ffffff" stroke-width="2"/>
            </g>
            
          </svg>
        </div>
      </div>
      <div style="text-align:center; margin-top:4px;">
        <span id="fear-greed-value" style="font-family:'Orbitron','Courier New',monospace; font-size:32px; font-weight:700; color:#ffaa33; text-shadow:0 0 10px rgba(255,170,51,0.8);">--</span>
      </div>
    </div>
  </section>

      <!-- MODULE: source-panel -->
<!-- MODULE: sources -->
<section class="card source-panel">

        <h2 class="card-title">市场板块温度计</h2>

        <div id="source-bars">

        <div class="source-bar">

          <span class="source-label">上涨板块</span>

          <div class="source-progress">

            <div class="source-fill" style="width:6%;background:var(--neon-red)"></div>

          </div>

          <span class="source-value" style="color:var(--neon-red)">6</span>

        </div>

      

        <div class="source-bar">

          <span class="source-label">下跌板块</span>

          <div class="source-progress">

            <div class="source-fill" style="width:9%;background:var(--neon-green)"></div>

          </div>

          <span class="source-value" style="color:var(--neon-green)">9</span>

        </div>

      

        <div class="source-bar">

          <span class="source-label">平均涨跌</span>

          <div class="source-progress">

            <div class="source-fill" style="width:50.12%;background:var(--neon-red)"></div>

          </div>

          <span class="source-value" style="color:var(--neon-red)">0.01%</span>

        </div>

      

        <div class="source-bar">

          <span class="source-label">最大涨幅</span>

          <div class="source-progress">

            <div class="source-fill" style="width:14.8%;background:var(--neon-red)"></div>

          </div>

          <span class="source-value" style="color:var(--neon-red)">2.96%</span>

        </div>

      

        <div class="source-bar">

          <span class="source-label">最大跌幅</span>

          <div class="source-progress">

            <div class="source-fill" style="width:13.600000000000001%;background:var(--neon-green)"></div>

          </div>

          <span class="source-value" style="color:var(--neon-green)">-2.72%</span>

        </div>

      </div>

      </section>

