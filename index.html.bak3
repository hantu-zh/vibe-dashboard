yframes css-13erb5t-antFadeOut{0%{opacity:1;}100%{opacity:0;}}</style><style data-rc-order="prependQueue" data-rc-priority="-999" data-css-hash="_effect-css-13erb5t-antZoomIn">@keyframes css-13erb5t-antZoomIn{0%{transform:scale(0.2);opacity:0;}100%{transform:scale(1);opacity:1;}}</style><style data-rc-order="prependQueue" data-rc-priority="-999" data-css-hash="_effect-css-13erb5t-antZoomOut">@keyframes css-13erb5t-antZoomOut{0%{transform:scale(1);}100%{transform:scale(0.2);opacity:0;}}</style><style data-rc-order="prependQueue" data-css-hash="uggb7r" data-token-hash="1ypsd8t">.anticon{display:inline-flex;align-items:center;color:inherit;font-style:normal;line-height:0;text-align:center;text-transform:none;vertical-align:-0.125em;text-rendering:optimizeLegibility;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;}.anticon >*{line-height:1;}.anticon svg{display:inline-block;}.anticon .anticon .anticon-icon{display:block;}</style>

  

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>方瑟的openclaw A股情绪雷达</title>


  <style>

    :root {

      --neon-pink: #ff2d6a;

      --neon-cyan: #00fff2;

      --neon-purple: #b829ff;

      --neon-green: #39ff14;

      --neon-red: #ff2d2d;

      --neon-orange: #ff6b35;

      --dark-bg: #0a0a0f;

      --card-bg: rgba(15, 15, 25, 0.85);

      --border-glow: rgba(255, 45, 106, 0.3);

    }


    * { margin: 0; padding: 0; box-sizing: border-box; }


    body {

      font-family: 'Noto Sans SC', sans-serif;

      background: var(--dark-bg);

      color: #e0e0e0;

      min-height: 100vh;

      overflow-x: hidden;

      position: relative;

    }


    body::before {

      content: '';

      position: fixed;

      top: 0; left: 0;

      width: 100%; height: 100%;

      background: 

        linear-gradient(90deg, rgba(255,45,106,0.03) 1px, transparent 1px),

        linear-gradient(rgba(0,255,242,0.03) 1px, transparent 1px);

      background-size: 50px 50px;

      animation: gridMove 20s linear infinite;

      pointer-events: none;

      z-index: 0;

    }


    @keyframes gridMove {

      0% { transform: translate(0, 0); }

      100% { transform: translate(50px, 50px); }

    }


    body::after {

      content: '';

      position: fixed;

      top: 0; left: 0;

      width: 100%; height: 4px;

      background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);

      animation: scanLine 4s ease-in-out infinite;

      pointer-events: none;

      z-index: 1000;

      opacity: 0.5;

    }


    @keyframes scanLine {

      0%, 100% { top: -10px; opacity: 0; }

      50% { opacity: 0.7; }

      100% { top: 100%; }

    }


    .container {

      position: relative;

      z-index: 1;

      max-width: 1800px;

      margin: 0 auto;

      padding: 20px;

    }


    .header {

      text-align: center;

      margin-bottom: 25px;

      padding: 15px;

    }


    .logo {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 2.5rem;

      font-weight: 900;

      letter-spacing: 6px;

      background: linear-gradient(135deg, var(--neon-red), var(--neon-orange), var(--neon-pink));

      -webkit-background-clip: text;

      -webkit-text-fill-color: transparent;

      background-clip: text;

      animation: logoPulse 2s ease-in-out infinite;

    }


    @media (max-width: 768px) {

      .logo { font-size: 1.3rem; letter-spacing: 2px; }

      .tagline { font-size: 0.65rem; letter-spacing: 1px; }

    }


    @keyframes logoPulse {

      0%, 100% { filter: brightness(1); }

      50% { filter: brightness(1.2); }

    }


    .tagline {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.85rem;

      color: var(--neon-cyan);

      letter-spacing: 3px;

      margin-top: 8px;

    }


    .status-bar {

      display: flex;

      justify-content: center;

      gap: 25px;

      margin-top: 15px;

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.7rem;

    }


    .status-item {

      display: flex;

      align-items: center;

      gap: 6px;

    }


    .status-dot {

      width: 8px; height: 8px;

      border-radius: 50%;

      animation: blink 1.5s ease-in-out infinite;

    }


    .status-dot.active { background: var(--neon-green); box-shadow: 0 0 10px var(--neon-green); }

    .status-dot.warning { background: var(--neon-orange); box-shadow: 0 0 10px var(--neon-orange); }

    .status-dot.error { background: var(--neon-red); box-shadow: 0 0 10px var(--neon-red); }


    @keyframes blink {

      0%, 100% { opacity: 1; }

      50% { opacity: 0.4; }

    }


    .dashboard-grid {

      display: grid;

      grid-template-columns: 280px 1fr 320px;

      grid-template-rows: auto auto auto auto auto auto;

      gap: 18px;

    }


    .card {

      background: var(--card-bg);

      border: 1px solid var(--border-glow);

      border-radius: 10px;

      padding: 18px;

      position: relative;

      overflow: hidden;

      backdrop-filter: blur(10px);

      transition: all 0.3s ease;

    }


    .card::before {

      content: '';

      position: absolute;

      top: 0; left: 0; right: 0;

      height: 2px;

      background: linear-gradient(90deg, transparent, var(--neon-pink), transparent);

    }


    .card:hover {

      border-color: var(--neon-pink);

      box-shadow: 0 0 25px rgba(255, 45, 106, 0.15);

    }


    
    .title-icon {
      font-size: 1.1em;
      margin-right: 8px;
    }
    .title-hint {
      font-size: 0.6em;
      color: rgba(255,255,255,0.4);
      background: rgba(255,255,255,0.05);
      padding: 2px 8px;
      border-radius: 4px;
      margin-left: 8px;
    }

    
    /* RPS 荧光样式 */

    .rps-stat {
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 0.75rem;
    }
    .rps-stat.strong {
      background: rgba(255, 0, 40, 0.2);
      color: #ff0028;
      box-shadow: 0 0 10px rgba(255, 0, 40, 0.3);
    }
    .rps-stat.weak {
      background: rgba(57, 255, 20, 0.15);
      color: #39ff14;
      box-shadow: 0 0 10px rgba(57, 255, 20, 0.3);
    }
    .rps-divider {
      color: rgba(255,255,255,0.3);
      margin: 0 8px;
    }
    .rps-formula {
      color: rgba(255,255,255,0.5);
      font-size: 0.7rem;
    }


    .rps-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }
    .rps-table {
      background: rgba(255, 255, 255, 0.02);
      border-radius: 8px;
      overflow: hidden;
    }
    .rps-table th {
      background: linear-gradient(90deg, rgba(255,0,40,0.15) 0%, rgba(255,0,146,0.15) 100%);
      color: rgba(255,255,255,0.8);
      padding: 10px 8px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .rps-table td {
      padding: 8px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.75rem;
    }
    .rps-table tr:hover {
      background: rgba(255,0,146,0.08);
    }
    .rps-bar {
      height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.1);
      overflow: hidden;
      position: relative;
    }
    .rps-bar::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%);
      animation: rps-shine 2s infinite;
    }
    @keyframes rps-shine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
    .rps-num {
      font-weight: 600;
      text-shadow: 0 0 8px currentColor;
    }
    .rps-strength {
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 0.65rem;
      font-weight: 500;
      text-transform: uppercase;
    }
    .rps-sector-name {
      font-weight: 500;
    }

    .card-title {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.75rem;

      letter-spacing: 2px;

      color: var(--neon-cyan);

      margin-bottom: 12px;

      text-transform: uppercase;

      display: flex;

      align-items: center;

      gap: 8px;

    }


    .card-title::before { content: '>'; color: var(--neon-pink); }


    /* Sentiment Meter */

    .sentiment-meter {

      grid-column: 1;

      grid-row: 1;

    }


    .slowrise-panel { display: none; }


    .sector-panel {

      grid-column: 2;

      grid-row: 1;

      width: 100%;

      min-width: 0;

    }


    .stock-panel {

      grid-column: 1 / -1;

      grid-row: 2;

    }


    .alert-panel {

      grid-column: 3;

      grid-row: 2;

      overflow: visible !important;

    }

/* US Stock Picks Panel - 放在异动面板下方 */
    .us-stock-panel {
      grid-column: 1 / -1;
      grid-row: 4;
    }

.source-panel {

      grid-column: 1 / -1;

      grid-row: 5;

    }


    .rps-panel {

      grid-column: 1 / -1;

      grid-row: 6;

      min-width: 0;
      overflow-x: auto;
    }



    .rps-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }
    .rps-table {

      width: 100%;

      min-width: 500px;

      table-layout: auto;

      border-collapse: collapse;

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.8rem;

    }


    .rps-table th {

      text-align: left;

      padding: 8px 12px;

      border-bottom: 1px solid rgba(255,45,106,0.3);

      color: var(--neon-cyan);

      font-size: 0.7rem;

      letter-spacing: 1px;

      text-transform: uppercase;

    }


    .rps-table td {

      padding: 6px 12px;

      border-bottom: 1px solid rgba(255,255,255,0.05);

    }


    .rps-table tr:hover {

      background: rgba(255,45,106,0.08);

    }


    .rps-bar {

      height: 6px;

      border-radius: 3px;

      transition: width 0.8s ease;

      min-width: 2px;

    }


    .rps-cell {

      display: flex;

      align-items: center;

      gap: 8px;

    }


    .rps-num {

      font-weight: 700;

      min-width: 32px;

      text-align: right;

    }


    .rps-sector-name {

      font-family: 'Noto Sans SC', sans-serif;

      font-weight: 600;

      font-size: 0.85rem;

    }


    .rps-strength {

      font-size: 0.7rem;

      padding: 2px 6px;

      border-radius: 3px;

      font-weight: 600;

      white-space: nowrap;

    }


    .rps-trend {

      font-size: 0.9rem;

    }

    .rps-trend.up {

      color: var(--neon-red) !important;

    }

    .rps-trend.down {

      color: var(--neon-green) !important;

    }


    .meter-container {

      height: 200px;

      display: flex;

      flex-direction: column;

      align-items: center;

      justify-content: center;

    }


    .gauge { width: 160px; height: 160px; position: relative; }


    .gauge-bg { fill: none; stroke: rgba(255,255,255,0.1); stroke-width: 12; }


    .gauge-fill {

      fill: none;

      stroke-width: 12;

      stroke-linecap: round;

      transition: stroke-dashoffset 1s ease;

      filter: drop-shadow(0 0 8px currentColor);

    }


    .gauge-text {

      position: absolute;

      top: 0; left: 0; right: 0; bottom: 0;

      text-align: center;

      padding-left: 35px;

    }


    .gauge-score {

      font-family: 'Orbitron', 'Courier New', monospace !important;

      font-size: 4rem;

      font-weight: 700;

      line-height: 165px;

      background: linear-gradient(135deg, #00ffff, #ff00ff, #00ffff);

      background-size: 200% 200%;

      -webkit-background-clip: text;

      -webkit-text-fill-color: transparent;

      background-clip: text;

      opacity: 0.9;

      animation: gauge-pulse 2s ease-in-out infinite;

    }

    @keyframes gauge-pulse {

      0%, 100% { opacity: 0.85; transform: scale(1); }

      50% { opacity: 1; transform: scale(1.02); }

    }


    .gauge-label {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.6rem;

      color: var(--neon-cyan);

      letter-spacing: 1px;

      margin-top: -35px;

    }


    .sentiment-breakdown { margin-top: 15px; width: 100%; }


    .breakdown-item {

      display: flex;

      justify-content: space-between;

      align-items: center;

      padding: 6px 0;

      border-bottom: 1px solid rgba(255,255,255,0.05);

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.75rem;

    }


    .breakdown-bar {

      flex: 1;

      height: 4px;

      background: rgba(255,255,255,0.1);

      margin: 0 12px;

      border-radius: 2px;

      overflow: hidden;

    }


    .breakdown-fill {

      height: 100%;

      border-radius: 2px;

      transition: width 0.8s ease;

    }


    /* Sector Panel - grid position defined above */


    .sector-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .tab-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: 'Noto Sans SC', sans-serif;
      font-size: 0.75rem;
      padding: 8px 16px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background: rgba(255, 255, 255, 0.03);
      color: rgba(255, 255, 255, 0.7);
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.25s ease;
      position: relative;
      overflow: hidden;
    }

    .tab-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.05) 100%);
      opacity: 0;
      transition: opacity 0.25s ease;
    }

    .tab-btn:hover::before {
      opacity: 1;
    }

    .tab-btn:hover {
      border-color: rgba(255, 255, 255, 0.3);
      color: #fff;
      transform: translateY(-1px);
    }

    .tab-btn.active {
      background: linear-gradient(135deg, rgba(255, 0, 146, 0.2) 0%, rgba(255, 0, 146, 0.1) 100%);
      border-color: #ff0092;
      color: #fff;
      box-shadow: 0 0 20px rgba(255, 0, 146, 0.3);
    }

    .tab-icon {
      font-size: 1rem;
      line-height: 1;
    }

    .tab-label {
      font-weight: 700;
    }

    .tab-badge {
      background: rgba(255, 255, 255, 0.1);
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.6);
    }

    .tab-btn.active .tab-badge {
      background: rgba(255, 0, 146, 0.3);
      color: #fff;
    }

    .tab-hint {
      font-size: 0.6rem;
      color: rgba(255, 255, 255, 0.4);
      background: rgba(255, 255, 255, 0.05);
      padding: 2px 6px;
      border-radius: 4px;
    }

    .tab-btn[data-type="industry"]:hover,
    .tab-btn[data-type="industry"].active {
      background: linear-gradient(135deg, rgba(255, 0, 40, 0.2) 0%, rgba(255, 0, 40, 0.1) 100%);
      border-color: #ff0028;
      box-shadow: 0 0 20px rgba(255, 0, 40, 0.3);
    }

    .tab-btn[data-type="concept"]:hover,
    .tab-btn[data-type="concept"].active {
      background: linear-gradient(135deg, rgba(255, 0, 146, 0.2) 0%, rgba(255, 0, 146, 0.1) 100%);
      border-color: #ff0092;
      box-shadow: 0 0 20px rgba(255, 0, 146, 0.3);
    }

    .tab-btn[data-type="slowrise"] {
      border-color: rgba(57, 255, 20, 0.3);
      color: rgba(57, 255, 20, 0.8);
    }

    .tab-btn[data-type="slowrise"]:hover,

    .tab-btn[data-type="slowrise"].active {

      background: var(--neon-green);

      color: #000;

      border-color: var(--neon-green);

    }


    .tab-btn[data-type="concept"] {

      border-color: rgba(184, 41, 255, 0.5);

      color: var(--neon-purple);

    }


    .tab-btn[data-type="concept"]:hover,

    .tab-btn[data-type="concept"].active {

      background: var(--neon-purple);

      color: #fff;

      border-color: var(--neon-purple);

    }


    .sector-grid {

      display: block;

      width: 100%;

      min-width: 0;

    }


    .sector-item {

      background: rgba(255,255,255,0.02);

      border-radius: 6px;

      padding: 10px 8px;

      text-align: center;

      transition: all 0.3s ease;

      cursor: pointer;

      border-left: 2px solid transparent;

    }


    .sector-item:hover {

      background: rgba(255,45,106,0.1);

      transform: translateY(-2px);

    }


    .sector-item.up { border-left-color: var(--neon-red); }

    .sector-item.down { border-left-color: var(--neon-green); }


    .sector-name {

      font-size: 0.8rem;

      font-weight: 500;

      margin-bottom: 4px;

      white-space: nowrap;

      overflow: hidden;

      text-overflow: ellipsis;

    }


    .sector-change {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.9rem;

      font-weight: 700;

    }


    .up { color: var(--neon-red); }

    .down { color: var(--neon-green); }


    /* Stock Panel */

    .stock-list {

      display: grid;

      grid-template-columns: repeat(3, 1fr);

      gap: 8px;

      max-height: 300px;

      overflow-y: auto;

    }

    #chase-strong-stocks-list,

    #stock-list {

      grid-template-columns: repeat(3, 1fr) !important;

    }


    @media (max-width: 768px) {

      #chase-strong-stocks-list,

      #stock-list {

        grid-template-columns: 1fr !important;

      }

    }


    .stock-item {

      display: flex;

      align-items: center;

      gap: 10px;

      padding: 10px 12px;

      background: rgba(255,255,255,0.02);

      border-radius: 6px;

      transition: all 0.3s ease;

      cursor: pointer;

    }


    .stock-item:hover { background: rgba(255,45,106,0.1); }


    .stock-rank {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.9rem;

      font-weight: 700;

      color: var(--neon-purple);

      min-width: 22px;

    }


    .stock-info { flex: 1; }


    .stock-name { font-size: 0.85rem; font-weight: 500; }


    .stock-code {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.65rem;

      color: rgba(255,255,255,0.4);

    }


    .stock-price {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.75rem;

      color: rgba(255,255,255,0.6);

    }


    .stock-change {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.9rem;

      font-weight: 700;

    }


    /* Alert Panel */

    .alert-panel {

      grid-column: 3;

      grid-row: 1;

      overflow: visible !important;

    }


    .alert-list {

      display: flex;

      flex-direction: column;

      gap: 8px;

    }


    .alert-item {

      display: flex;

      align-items: flex-start;

      gap: 10px;

      padding: 10px;

      border-radius: 6px;

      font-size: 0.8rem;

      animation: alertFadeIn 0.5s ease;

    }


    @keyframes alertFadeIn {

      from { opacity: 0; transform: translateX(-10px); }

      to { opacity: 1; transform: translateX(0); }

    }


    .alert-hot { background: rgba(255,45,45,0.15); border-left: 3px solid var(--neon-red); }

    .alert-warning { background: rgba(255,107,53,0.15); border-left: 3px solid var(--neon-orange); }

    .alert-info { background: rgba(0,255,242,0.1); border-left: 3px solid var(--neon-cyan); }


    .alert-time {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.6rem;

      color: rgba(255,255,255,0.4);

      margin-top: 2px;

    }


    /* Concept Panel *//* Slow Rise */

    .slowrise-empty {

      text-align: center;

      padding: 20px;

      color: rgba(255,255,255,0.3);

      font-size: 0.8rem;

    }


    /* Source Monitor */

    .source-bar {

      display: flex;

      align-items: center;

      gap: 15px;

      padding: 12px 0;

      border-bottom: 1px solid rgba(255,255,255,0.05);

    }


    .source-bar:last-child { border-bottom: none; }


    .source-label {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.75rem;

      color: rgba(255,255,255,0.6);

      min-width: 100px;

    }


    .source-progress {

      flex: 1;

      height: 8px;

      background: rgba(255,255,255,0.1);

      border-radius: 4px;

      overflow: hidden;

    }


    .source-fill {

      height: 100%;

      border-radius: 4px;

      transition: width 0.8s ease;

    }


    .source-value {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.85rem;

      font-weight: 700;

      min-width: 60px;

      text-align: right;

    }


    .loading {

      display: flex;

      align-items: center;

      justify-content: center;

      height: 100px;

      color: var(--neon-cyan);

      font-family: 'Noto Sans SC', sans-serif;

    }


    .error-msg {

      color: var(--neon-red);

      text-align: center;

      padding: 20px;

    }


    /* Responsive */

    @media (max-width: 1400px) {

      .dashboard-grid { grid-template-columns: 260px 1fr 280px; }

      .stock-list { grid-template-columns: repeat(2, 1fr); }

    }


    @media (max-width: 1100px) {

      .dashboard-grid { grid-template-columns: 1fr 1fr; }

      .sentiment-meter { grid-column: 1; grid-row: 1; }

      .sector-panel { grid-column: 2; grid-row: 1; width: 100%; min-width: 0; }

      .stock-panel { grid-column: 1 / -1; grid-row: 2; }

      .us-stock-panel { grid-column: 1 / -1; grid-row: 4; }

      .alert-panel { grid-column: 2; }

      .source-panel { grid-column: 1 / -1; grid-row: 5; }

      .rps-panel { grid-column: 1 / -1; grid-row: 6; }

    }


    @media (max-width: 768px) {

      /* Enable horizontal scroll on small screens */

      html, body {

        overflow-x: auto;

        min-width: 100vw;

      }

      .dashboard-grid {

        display: flex;

        flex-direction: column;

        min-width: 100vw;

        width: 100vw;

        padding-right: 20px;

      }

      .sentiment-meter, .sector-panel, .stock-panel, .alert-panel, .source-panel, .rps-panel, .us-stock-panel {

        min-width: 90vw;

        width: 90vw;

        flex-shrink: 0;

      }

  
    .rps-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }
    .rps-table {

        min-width: 500px;

        width: auto;

        table-layout: auto;

      }

      .rps-panel {

        -webkit-overflow-scrolling: touch;

      }

      .stock-list { grid-template-columns: 1fr; }

      

      /* Mobile optimization */

      body { font-size: 14px; padding: 8px; }

      .card { padding: 12px; margin: 8px 0; border-radius: 8px; }

      
    .title-icon {
      font-size: 1.1em;
      margin-right: 8px;
    }
    .title-hint {
      font-size: 0.6em;
      color: rgba(255,255,255,0.4);
      background: rgba(255,255,255,0.05);
      padding: 2px 8px;
      border-radius: 4px;
      margin-left: 8px;
    }

    
    /* RPS 荧光样式 */

    .rps-stat {
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 0.75rem;
    }
    .rps-stat.strong {
      background: rgba(255, 0, 40, 0.2);
      color: #ff0028;
      box-shadow: 0 0 10px rgba(255, 0, 40, 0.3);
    }
    .rps-stat.weak {
      background: rgba(57, 255, 20, 0.15);
      color: #39ff14;
      box-shadow: 0 0 10px rgba(57, 255, 20, 0.3);
    }
    .rps-divider {
      color: rgba(255,255,255,0.3);
      margin: 0 8px;
    }
    .rps-formula {
      color: rgba(255,255,255,0.5);
      font-size: 0.7rem;
    }


    .rps-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }
    .rps-table {
      background: rgba(255, 255, 255, 0.02);
      border-radius: 8px;
      overflow: hidden;
    }
    .rps-table th {
      background: linear-gradient(90deg, rgba(255,0,40,0.15) 0%, rgba(255,0,146,0.15) 100%);
      color: rgba(255,255,255,0.8);
      padding: 10px 8px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .rps-table td {
      padding: 8px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.75rem;
    }
    .rps-table tr:hover {
      background: rgba(255,0,146,0.08);
    }
    .rps-bar {
      height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.1);
      overflow: hidden;
      position: relative;
    }
    .rps-bar::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%);
      animation: rps-shine 2s infinite;
    }
    @keyframes rps-shine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
    .rps-num {
      font-weight: 600;
      text-shadow: 0 0 8px currentColor;
    }
    .rps-strength {
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 0.65rem;
      font-weight: 500;
      text-transform: uppercase;
    }
    .rps-sector-name {
      font-weight: 500;
    }

    .card-title { font-size: 16px; margin-bottom: 8px; }

      .sector-item { padding: 8px 10px; font-size: 13px; }

      .sector-name { font-size: 13px; }

      .sector-change { font-size: 12px; }

      .tab-btn { padding: 6px 12px; font-size: 13px; }

      .stock-item { padding: 10px; font-size: 13px; }

      .stock-rank { width: 24px; height: 24px; font-size: 11px; }

      .stock-name { font-size: 13px; }

      .stock-code { font-size: 11px; }

      .stock-change { font-size: 13px; }

      .stock-price { font-size: 12px; }

      .alert-item { padding: 10px; font-size: 13px; }

      .loading, .error-msg { padding: 20px; font-size: 13px; }

      .toolbar { padding: 8px; }

      .toolbar-btn { padding: 8px 12px; font-size: 13px; }

      #status-text { font-size: 11px; }

      .picks-section { margin: 8px 0; padding: 8px; background: rgba(255,255,255,0.04); border-radius: 6px; }

      .picks-header { font-size: 13px; padding-bottom: 6px; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 6px; }

      .picks-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 4px; font-size: 11px; border-bottom: 1px solid rgba(255,255,255,0.04); }

      .picks-code { flex: 1; font-size: 11px; min-width: 100px; }

      .picks-price { margin: 0 8px; font-size: 12px; }

      .picks-change { margin-left: 8px; font-size: 11px; min-width: 60px; text-align: right; }
      .picks-info { margin-left: 6px; font-size: 10px; padding: 1px 6px; border-radius: 3px; background: rgba(0,255,242,0.12); color: var(--neon-cyan); white-space: nowrap; }

      .picks-level { margin-left: 6px; font-size: 10px; padding: 1px 5px; color: #FFD700; }

      .picks-count { font-size: 11px; margin-left: 6px; opacity: 0.7; }
      .us-update-time { font-size: 11px; color: rgba(255,255,255,0.5); margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .rps-update-time { font-size: 11px; color: rgba(255,255,255,0.5); margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid rgba(255,255,255,0.06); }
      .picks-row-header { opacity: 0.5; font-size: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); }

      .us-stock-container { display: flex; flex-direction: column; gap: 8px; max-height: none; overflow: visible; width: 100%; }
      .us-stock-container .picks-section { margin: 0; width: 100%; }
      .us-stock-container .us-table-wrap { width: 100%; }
      .us-table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 11px; }
      .us-table thead th { font-size: 9px; opacity: 0.5; text-align: center; padding: 6px 10px 5px; border-bottom: 1px solid rgba(255,255,255,0.12); white-space: nowrap; letter-spacing: 0.3px; }
      .us-table tbody tr:nth-child(even) {
  background: rgba(255,255,255,0.12) !important;
}
.us-table tbody td { padding: 6px 10px; border-bottom: 1px solid rgba(255,255,255,0.04); white-space: nowrap; }
      .us-table .us-code { font-family: 'JetBrains Mono', monospace; min-width: 56px; }
      .us-table .us-name { min-width: 60px; }
      .us-table .num { text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 10px; min-width: 42px; }
      .us-table .us-sector { min-width: 50px; }
      .us-table th, .us-table td { white-space: nowrap !important; }

      /* US Stock 11-column table */
      .us-table-wrap { overflow-x: auto; margin: 4px 0; -webkit-overflow-scrolling: touch; }
      .us-table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 11px; }
      .us-table thead th { font-size: 9px; opacity: 0.5; text-align: center; padding: 6px 10px 5px; border-bottom: 1px solid rgba(255,255,255,0.12); white-space: nowrap; letter-spacing: 0.3px; }
      .us-table tbody td { padding: 6px 10px; border-bottom: 1px solid rgba(255,255,255,0.04); white-space: nowrap; }
      .us-table .us-code { font-family: 'JetBrains Mono', monospace; min-width: 56px; }
      .us-table .us-name { min-width: 60px; }
      .us-table .num { text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 10px; min-width: 42px; }
      .us-table .us-sector { min-width: 50px; }
      .us-table tbody tr:hover { background: rgba(0,255,242,0.04); }

      .picks-time { font-size: 11px; margin-left: 8px; color: var(--neon-cyan); opacity: 0.8; }
      .picks-empty { font-size: 11px; color: rgba(255,255,255,0.35); padding: 8px 4px; font-style: italic; text-align: center; }
      .picks-delay { color: #ff9800; font-size: 10px; margin-left: 6px; font-style: normal; }
      .picks-waiting { color: rgba(255,255,255,0.25); font-size: 11px; padding: 8px 4px; text-align: center; }
      .picks-section-empty { opacity: 0.6; }
      .picks-schedule { font-size: 10px; margin-left: 6px; opacity: 0.5; }

  
    .rps-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }
    .rps-table { font-size: 11px; }
    
    /* 板块表格荧光样式 */
    .concept-tbl-wrap {
      background: rgba(255, 255, 255, 0.02);
      border-radius: 10px;
      overflow: hidden;
    }
    .concept-tbl {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.75rem;
    }
    .concept-tbl th {
      background: linear-gradient(90deg, rgba(255,0,146,0.2) 0%, rgba(0,230,118,0.2) 100%);
      color: rgba(255,255,255,0.9);
      padding: 12px 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.7rem;
      border-bottom: 1px solid rgba(255,255,255,0.15);
    }
    .concept-tbl td {
      padding: 10px 8px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      transition: all 0.2s ease;
    }
    .concept-tbl tr:hover td {
      background: rgba(255,0,146,0.1);
    }
    .rank-cell {
      font-weight: 700;
      color: rgba(255,255,255,0.5);
      font-size: 0.8rem;
    }
    .sector-name-cell {
      font-weight: 500;
      color: #fff;
    }
    .sector-link {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s;
    }
    .sector-link:hover {
      color: #ff0092;
    }
    .change-cell {
      font-weight: 600;
      font-family: 'Noto Sans SC', sans-serif;
      text-shadow: 0 0 8px currentColor;
    }
    .str-cell {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .rps-bar {
      flex: 1;
      height: 8px;
      background: rgba(255,255,255,0.1);
      border-radius: 4px;
      overflow: hidden;
      position: relative;
    }
    .rps-fill {
      height: 100%;
      border-radius: 4px;
      position: relative;
      transition: width 0.5s ease;
    }
    .rps-fill::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%);
      animation: bar-shine 2s infinite;
    }
    @keyframes bar-shine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
    .str-pct {
      font-weight: 600;
      font-family: 'Noto Sans SC', sans-serif;
      font-size: 0.7rem;
      min-width: 50px;
      text-align: right;
      text-shadow: 0 0 8px currentColor;
    }

    .sector-table { width: 100%; table-layout: fixed; }

      .rps-table th, .rps-table td { padding: 5px 8px; white-space: nowrap; }

      .rps-cell { flex-direction: column; gap: 2px; }

      .rps-cell .rps-num { font-size: 12px; }

    }


    @media (max-width: 480px) {

      .sector-grid { width: 100%; }

      .stock-list { gap: 6px; }

      .sector-tabs { gap: 4px; }

      .tab-btn { padding: 5px 10px; font-size: 12px; }

    }


    /* Bottom toolbar */

    .toolbar {

      position: fixed;

      bottom: 0;

      left: 0;

      right: 0;

      background: rgba(10,10,15,0.95);

      border-top: 1px solid var(--border-glow);

      padding: 10px 20px;

      display: flex;

      align-items: center;

      justify-content: space-between;

      z-index: 999;

      backdrop-filter: blur(10px);

    }


    .toolbar-left {

      display: flex;

      align-items: center;

      gap: 15px;

    }


    .toolbar-info {

      font-family: 'Noto Sans SC', sans-serif;

      font-size: 0.7rem;

      color: var(--neon-cyan);

      display: flex;

      align-items: center;

      gap: 8px;

    }


    .toolbar-badge {

      background: rgba(0,255,242,0.1);

      border: 1px solid rgba(0,255,242,0.3);

      border-radius: 4px;

      padding: 3px 8px;

      color: var(--neon-cyan);

    }


/* 访问计数器样式 */

    .visit-counter {

      text-align: center;

      padding: 20px;

      margin-top: 30px;

      color: var(--text-secondary);

      font-size: 0.85rem;

      opacity: 0.7;

    }


    .visit-counter .counter-value {

      display: inline-block;

      background: rgba(0, 255, 136, 0.1);

      color: var(--neon-green);

      padding: 4px 12px;

      border-radius: 12px;

      margin-left: 8px;

      font-weight: 600;

      font-family: 'Noto Sans SC', sans-serif;

    }


    .visit-counter .counter-note {

      font-size: 12px;

      color: rgba(255, 255, 255, 0.6);

      margin-left: 12px;

    }

  
    /* ===== Sector Table (行业) ===== */
    .sector-tbl-wrap {
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
    }
    /* ===== Sector Table (行业) ===== */
    .sector-tbl-wrap {
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
    }
    .sector-tbl {
      width: 100%;
      min-width: 100%;
      table-layout: fixed;
      border-collapse: collapse;
      font-family: 'Noto Sans SC', sans-serif;
      font-size: 0.78rem;
    }
    .sector-tbl thead tr {
      background: rgba(0,229,255,0.06);
      border-bottom: 1px solid rgba(0,229,255,0.25);
    }
    .sector-tbl th {
      padding: 6px 10px;
      color: #00e5cc;
      font-size: 0.64rem;
      font-weight: 600;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .sector-tbl tbody tr:hover td { background: rgba(0,229,255,0.04); }
    .sector-tbl td {
      padding: 5px 10px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .rank-cell {
      text-align: right;
      color: rgba(0,229,255,0.8);
      font-family: 'Noto Sans SC', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      min-width: 40px;
    }
    /* Concept Table rank/name 动态颜色 + 发光 */
    .concept-tbl tbody tr[data-up] .rank-cell,
    .concept-tbl tbody tr[data-up] .sector-name-cell { color: #ff0092; text-shadow: 0 0 6px #ff0092; }
    .concept-tbl tbody tr[data-down] .rank-cell,
    .concept-tbl tbody tr[data-down] .sector-name-cell { color: #5c6bc0; text-shadow: 0 0 6px #5c6bc0; }
    .concept-tbl tbody tr[data-up] .sector-name-cell a,
    .concept-tbl tbody tr[data-down] .sector-name-cell a { color: inherit; }
    /* Concept Table 第一列加宽 */
    .concept-tbl th:first-child { width: 44px; }
    .concept-tbl td.rank-cell { min-width: 40px; }
    /* rank/name 颜色随涨跌幅变化 + 发光效果 */
    .sector-tbl tbody tr[data-up] .rank-cell,
    .sector-tbl tbody tr[data-up] .sector-name-cell { color: #ff0028; text-shadow: 0 0 6px #ff0028; }
    .sector-tbl tbody tr[data-down] .rank-cell,
    .sector-tbl tbody tr[data-down] .sector-name-cell { color: #39ff14; text-shadow: 0 0 6px #39ff14; }
    .sector-tbl tbody tr[data-up] .sector-name-cell a,
    .sector-tbl tbody tr[data-down] .sector-name-cell a { color: inherit; }
    .sector-name-cell a.sector-link {
      text-decoration: none;
      font-family: 'Noto Sans SC', sans-serif;
